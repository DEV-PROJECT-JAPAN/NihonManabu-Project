@page
@model FrontendRazorPage.Pages.Admin.Level.CreateModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm Cấp độ mới";
}

<div class="mb-4">
  
    <h2 class="fw-bold text-dark m-0">Thêm Cấp độ JLPT mới</h2>
</div>

<div class="card border-0 shadow-sm rounded-3 bg-white p-4" style="max-width: 600px;">
    <form method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label fw-bold text-secondary">Tên cấp độ (Ví dụ: N5, N4)<span class="text-danger">*</span></label>
            <input type="text" class="form-control" asp-for="NewLevel.Name" required placeholder="Nhập tên cấp độ..." />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold text-secondary">Mô tả chi tiết<span class="text-danger">*</span></label>
            <textarea class="form-control" asp-for="NewLevel.Description" rows="4" required placeholder="Nhập mô tả cho cấp độ này..."></textarea>
        </div>

        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-success px-4 shadow-sm">
                <i class="fa-solid fa-plus me-1"></i> Tạo mới
            </button>
            <a href="/Admin/Level" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
        </div>
    </form>
</div>