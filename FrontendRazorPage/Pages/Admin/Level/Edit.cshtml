@page
@model FrontendRazorPage.Pages.Admin.Level.EditModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chỉnh sửa Cấp độ";
}

<div class="mb-4">
    <a href="/Admin/Level/Index" class="btn btn-light btn-sm text-secondary shadow-sm mb-2">
        <i class="fa-solid fa-arrow-left me-1"></i> Quay lại danh sách
    </a>
    <h2 class="fw-bold text-dark m-0">Chỉnh sửa Cấp độ</h2>
</div>

<div class="card border-0 shadow-sm rounded-3 bg-white p-4" style="max-width: 600px;">
    <form method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="LevelData.Id" />

        <div class="mb-3">
            <label class="form-label fw-bold text-secondary">Tên cấp độ</label>
            <input type="text" class="form-control" asp-for="LevelData.Name" required />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold text-secondary">Mô tả chi tiết</label>
            <textarea class="form-control" asp-for="LevelData.Description" rows="4" required></textarea>
        </div>

        <div class="d-flex gap-2 pt-2">
            <button type="submit" class="btn btn-warning px-4 shadow-sm text-dark fw-bold">
                <i class="fa-solid fa-floppy-disk me-1"></i> Lưu thay đổi
            </button>
            <a href="/Admin/Level/Index" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
        </div>
    </form>
</div>