@page
@model FrontendRazorPage.Pages.Admin.Level.IndexModel
@{
    Layout = "_AdminLayout"; // Ép trang này phải nuốt cái khung AdminLayout ở trên
    ViewData["Title"] = "Quản lý cấp độ";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark m-0">Quản lý Cấp độ JLPT</h2>
        <p class="text-muted m-0">Thêm, sửa, xóa các cấp độ học trong hệ thống</p>
    </div>
    <a href="/Admin/Level/Create" class="btn btn-primary shadow-sm">
        <i class="fa-solid fa-plus me-1"></i> Thêm cấp độ mới
    </a>
</div>

<div class="card border-0 shadow-sm rounded-3 overflow-hidden">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light border-bottom">
                <tr>
                    <th class="ps-4 py-3 text-muted" style="width: 80px;">ID</th>
                    <th class="py-3 text-muted" style="width: 150px;">Tên cấp độ</th>
                    <th class="py-3 text-muted">Mô tả ngắn</th>
                    <th class="pe-4 py-3 text-center" style="width: 200px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Levels != null && Model.Levels.Any())
                {
                    @foreach (var item in Model.Levels)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@item.Id</td>
                            <td>
                                <span class="badge bg-indigo-subtle text-primary fs-6 px-3 py-1 rounded-pill">
                                    @item.Name
                                </span>
                            </td>
                            <td class="text-secondary">@item.Description</td>
                            <td class="pe-4 text-center">
                                <a href="/Admin/Level/Edit?id=@item.Id" class="btn btn-sm btn-outline-warning me-1" title="Sửa">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline"
                                      onsubmit="return confirm('Cảnh báo: Bạn có chắc chắn muốn xóa cấp độ @item.Name này không? Hành động này không thể hoàn tác!');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted fst-italic">
                            Chưa có dữ liệu cấp độ nào trong hệ thống.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>