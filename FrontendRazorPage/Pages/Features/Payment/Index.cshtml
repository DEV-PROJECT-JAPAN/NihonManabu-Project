@page
@model FrontendRazorPage.Pages.Features.Payment.IndexModel
@{
}
<style>
    /* Tổng quan nền tối */
    .vip-container {
        background-color: #0f172a;
        color: #f8fafc;
        padding: 50px 20px;
        border-radius: 15px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        text-align: center;
        max-width: 900px;
        margin: auto;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .vip-title {
        font-size: 2.5rem;
        color: #0dcaf0;
        font-weight: bold;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .vip-subtitle {
        color: #94a3b8;
        font-size: 1.1rem;
        margin-bottom: 40px;
    }

    /* Thẻ quyền lợi */
    .perks-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .perk-card {
        background: rgba(30, 41, 59, 0.7);
        border: 1px solid rgba(13, 202, 240, 0.3);
        border-radius: 12px;
        padding: 25px;
        transition: transform 0.3s;
    }

    .perk-card:hover {
        transform: translateY(-5px);
        border-color: #0dcaf0;
        box-shadow: 0 0 15px rgba(13, 202, 240, 0.2);
    }

    .perk-card i {
        font-size: 2.5rem;
        color: #ff823a;
        margin-bottom: 15px;
    }

    .perk-card h4 {
        color: #f8fafc;
        margin-bottom: 10px;
        font-size: 1.2rem;
    }

    .perk-card p {
        color: #cbd5e1;
        font-size: 0.95rem;
    }

    /* Khu vực giá và thanh toán */
    .price-box {
        background: linear-gradient(145deg, #1e293b, #0f172a);
        border: 2px solid #ff823a;
        border-radius: 15px;
        padding: 40px 20px;
        margin-bottom: 30px;
    }

    .price-amount {
        font-size: 3rem;
        font-weight: bold;
        color: #ff823a;
    }

    .btn-upgrade {
        background: linear-gradient(90deg, #ff823a, #facc15);
        color: #000;
        border: none;
        padding: 15px 40px;
        font-size: 1.2rem;
        font-weight: bold;
        border-radius: 30px;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        margin-top: 20px;
    }

    .btn-upgrade:hover {
        transform: scale(1.05);
        box-shadow: 0 0 20px rgba(255, 130, 58, 0.6);
    }

    /* Khu vực hiển thị mã QR (Mặc định ẩn) */
    #qr-section {
        display: none;
        margin-top: 30px;
        padding-top: 30px;
        border-top: 1px dashed #334155;
        animation: fadeIn 0.5s ease-in-out;
    }

    #qr-image {
        max-width: 280px;
        border-radius: 10px;
        border: 3px solid #0dcaf0;
        padding: 5px;
        background: white;
    }

    .loading-spinner {
        display: none;
        color: #0dcaf0;
        margin: 20px 0;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="vip-container">
    <h1 class="vip-title"><i class="fas fa-crown" style="color: #ff823a;"></i>VIP</h1>
    <p class="vip-subtitle">Mở khóa sức mạnh tối đa - Ghi nhớ từ vựng không giới hạn</p>

    <div class="perks-grid">
        <div class="perk-card">
            <i class="fas fa-infinity"></i>
            <h4>Không giới hạn</h4>
            <p>Thêm vô số từ vựng vào Flashcard cá nhân từ file Excel mà không gặp bất kỳ rào cản nào.</p>
        </div>
        <div class="perk-card">
            <i class="fas fa-bolt"></i>
            <h4>Ưu tiên Gacha</h4>
            <p>Hệ thống trộn bài tốc độ cao, không có quảng cáo làm phiền luồng tập trung của bạn.</p>
        </div>
        <div class="perk-card">
            <i class="fas fa-medal"></i>
            <h4>Huy hiệu độc quyền</h4>
            <p>Sở hữu huy hiệu VIP vàng óng ánh sát bên tên tài khoản, thể hiện đẳng cấp người học chăm chỉ.</p>
        </div>
    </div>

    <div class="price-box">
        @if (Model.CurrentRole == "VIP")
        {
            <h2 style="color: #22c55e;"><i class="fas fa-check-circle"></i> CHÀO MỪNG VIP MEMBER</h2>
            <p>Bạn đang sử dụng gói Alpha VIP. Chúc bạn học tập hiệu quả!</p>
        }
        else
        {
            <div style="font-size: 1.2rem; color: #cbd5e1;">Chỉ với</div>
            <div class="price-amount">50.000đ <span style="font-size: 1rem; color: #94a3b8;">/ tháng</span></div>

            <button class="btn-upgrade" onclick="requestVipQr()">
                <i class="fas fa-rocket"></i> NÂNG CẤP NGAY
            </button>
            <div class="loading-spinner" id="loading-indicator">
                <i class="fas fa-spinner fa-spin fa-2x"></i>
                <p>Đang tạo mã thanh toán an toàn...</p>
            </div>
        }
    </div>

    <div id="qr-section">
        <h3 style="color: #0dcaf0; margin-bottom: 15px;">Quét mã QR để thanh toán</h3>
        <p style="color: #cbd5e1; font-size: 0.9rem; margin-bottom: 20px;">
            Mã QR đã chứa sẵn Số tiền và Nội dung chuyển khoản. Vui lòng <b>KHÔNG sửa nội dung</b>.
        </p>

        <img id="qr-image" src="" alt="Mã VietQR" />

        @* <div style="margin-top: 25px; padding: 15px; background: rgba(34, 197, 94, 0.1); border-left: 4px solid #22c55e; border-radius: 8px; text-align: left;">
            <p style="margin: 0; color: #cbd5e1; font-size: 0.95rem;">
                <i class="fas fa-info-circle" style="color: #22c55e;"></i>
                Sau khi chuyển khoản thành công, hệ thống Webhook sẽ tự động xác nhận và cấp quyền VIP cho tài khoản <b>@Model.UserName</b> trong vòng 1-3 phút. Bạn không cần làm gì thêm!
            </p>
        </div> *@
    </div>
</div>

<script>
    async function requestVipQr() {
        document.querySelector('.btn-upgrade').style.display = 'none';
        document.getElementById('loading-indicator').style.display = 'block';

        // 1. Lấy JWT từ bộ nhớ
        const token = localStorage.getItem('token'); 
        
        // Log ra Console để chắc chắn token có tồn tại
        console.log("Token chuẩn bị gửi đi: ", token ? "ĐÃ CÓ TOKEN" : "TRỐNG TRƠN");

        if (!token) {
            alert('Bạn phải đăng nhập lại để thực hiện chức năng này!');
            resetUi();
            return;
        }

        try {
            // 2. Gọi thẳng vào PageModel cùng file, đính kèm Token
            const response = await fetch('?handler=GenerateQr', {
                method: 'GET',
                headers: { 
                    'Authorization': 'Bearer ' + token 
                }
            });

            const data = await response.json();

            // 3. Xử lý kết quả
            if (data.success) {
                document.getElementById('loading-indicator').style.display = 'none';
                document.getElementById('qr-image').src = data.qrUrl;
                document.getElementById('qr-section').style.display = 'block';
            } else {
                alert(data.message); // Hiển thị rõ thông báo lỗi để biết kẹt ở FE hay BE
                resetUi();
            }
        } catch (error) {
            console.error("Lỗi:", error);
            alert('Lỗi kết nối máy chủ.');
            resetUi();
        }
    }

    function resetUi() {
        document.querySelector('.btn-upgrade').style.display = 'inline-block';
        document.getElementById('loading-indicator').style.display = 'none';
    }
    let checkInterval; // Biến giữ vòng lặp để lúc sau còn tắt đi

    async function requestVipQr() {
        document.querySelector('.btn-upgrade').style.display = 'none';
        document.getElementById('loading-indicator').style.display = 'block';

        const token = localStorage.getItem('token');
        if (!token) {
            alert('Bạn phải đăng nhập lại để thực hiện chức năng này!');
            resetUi();
            return;
        }

        try {
            const response = await fetch('?handler=GenerateQr', {
                method: 'GET',
                headers: { 'Authorization': 'Bearer ' + token }
            });
            const data = await response.json();

            if (data.success) {
                document.getElementById('loading-indicator').style.display = 'none';
                document.getElementById('qr-image').src = data.qrUrl;
                document.getElementById('qr-section').style.display = 'block';

                // 🚀 BẮT ĐẦU VÒNG LẶP HỎI THĂM
                startCheckingVipStatus(token);
            } else {
                alert(data.message);
                resetUi();
            }
        } catch (error) {
            alert('Lỗi kết nối máy chủ.');
            resetUi();
        }
    }

    function startCheckingVipStatus(token) {
        // Cứ mỗi 3 giây (3000ms) sẽ chạy đoạn code bên trong 1 lần
        checkInterval = setInterval(async () => {
            try {
                // Gọi lên Trạm trung chuyển PageModel
                const response = await fetch('?handler=CheckStatus', {
                    method: 'GET',
                    headers: { 'Authorization': 'Bearer ' + token }
                });

                if (response.ok) {
                    const data = await response.json();

                    // Nếu Backend trả về isVip = true
                    if (data.isVip === true) {
                        clearInterval(checkInterval); // Tắt vòng lặp ngay lập tức

                        alert("🎉 Ting ting! Đã nhận được thanh toán. Chào mừng VIP Member!");

                        // Tự động tải lại trang để áp dụng các quyền lợi VIP (ẩn nút, hiện huy hiệu)
                        window.location.reload();
                    }
                }
            } catch (error) {
                console.log("Đang chờ thanh toán...");
            }
        }, 3000);

        // Đặt đồng hồ đếm ngược: Sau 10 phút (600.000ms) nếu không thanh toán thì tự tắt vòng lặp cho đỡ nặng máy
        setTimeout(() => {
            clearInterval(checkInterval);
            console.log("Đã hết thời gian chờ thanh toán.");
        }, 600000);
    }

    function resetUi() {
        document.querySelector('.btn-upgrade').style.display = 'inline-block';
        document.getElementById('loading-indicator').style.display = 'none';
    }
</script>