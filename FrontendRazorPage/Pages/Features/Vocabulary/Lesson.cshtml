@page "{levelId:int}"
@model FrontendRazorPage.Pages.Vocabulary.LessonsModel
@{
    ViewData["Title"] = "Danh sách bài học";
}
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />


<div class="container py-5">
    <div class="d-flex align-items-center mb-5">
        <a asp-page="./Index" class="btn btn-light rounded-circle me-3 shadow-sm p-2 text-dark">
            <i class="fa-solid fa-arrow-left fs-5"></i>
        </a>
        <h2 class="fw-black text-dark m-0">Danh sách bài học</h2>
    </div>

    <div class="row g-4">
        @foreach (var les in Model.Lessons)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <a asp-page="./ListVocabulary" asp-route-lessonId="@les.Id" class="text-decoration-none d-block h-100">
                    <div class="card border-0 shadow-sm p-4 h-100 d-flex flex-column justify-content-between hover-card-jlpt" style="border-radius: 18px; background: white; border-left: 6px solid #ff9f43 !important;">
                        <div class="mb-3">
                            <h5 class="fw-black text-dark m-0">@les.Title</h5>
                        </div>
                        <div class="pt-2 border-top border-light d-flex justify-content-between align-items-center text-muted small">
                            <span><i class="fa-solid fa-list-ol me-1"></i>Thứ tự bài: @les.Order</span>
                            <span class="text-warning fw-bold">Vào học <i class="fa-solid fa-chevron-right ms-1 small"></i></span>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<style>
    .fw-black {
        font-weight: 900 !important;
    }

    .hover-card-jlpt {
        transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.25s ease;
        cursor: pointer;
        border: 1px solid #f1f5f9 !important;
    }

        .hover-card-jlpt:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 25px rgba(0, 0, 0, 0.05) !important;
            background-color: #fafafa !important;
        }
</style>