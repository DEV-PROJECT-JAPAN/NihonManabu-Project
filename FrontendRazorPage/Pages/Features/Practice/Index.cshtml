@page
@model FrontendRazorPage.Pages.Features.Practice.IndexModel
@{
    ViewData["Title"] = "Daily Vocabulary Draw - Gacha Style";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        /* ============================================
           ROOT VARIABLES & STYLING
           ============================================ */
        :root {
            --primary-color: #00d4ff;
            --secondary-color: #ffff00;
            --dark-bg: #0f1419;
            --card-bg: #1a1f2e;
            --text-light: #ffffff;
            --text-muted: #a0aec0;
            --success-color: #10b981;
            --border-radius: 12px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, var(--dark-bg) 0%, #1a1f2e 100%);
            color: var(--text-light);
            font-family: 'Quicksand', sans-serif;
            min-height: 100vh;
            padding: 2rem 1rem;
        }

        /* ============================================
           PAGE HEADER
           ============================================ */
        .page-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .page-title {
            font-family: 'Orbitron', monospace;
            font-size: 2.5rem;
            font-weight: 900;
            color: var(--primary-color);
            text-shadow: 0 0 20px rgba(0, 212, 255, 0.6);
            letter-spacing: 2px;
            margin-bottom: 0.5rem;
        }

        .page-subtitle {
            font-size: 1.1rem;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
        }

        .draw-info {
            font-size: 0.9rem;
            color: var(--primary-color);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* ============================================
           CARDS CONTAINER & GRID
           ============================================ */
        .cards-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
            background-color: rgba(26, 31, 46, 0.5);
            border-radius: var(--border-radius);
            border: 2px solid var(--primary-color);
            box-shadow: 0 0 30px rgba(0, 212, 255, 0.2);
        }

        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 2rem;
            margin-bottom: 2rem;
        }

        /* ============================================
           FLIP CARD STYLES (3D PERSPECTIVE)
           ============================================ */
        .flip-card {
            background-color: transparent;
            width: 100%;
            height: 250px;
            perspective: 1000px;
            cursor: pointer;
        }

        .flip-card-inner {
            position: relative;
            width: 100%;
            height: 100%;
            text-align: center;
            transition: transform 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            transform-style: preserve-3d;
            border-radius: var(--border-radius);
            box-shadow: 0 8px 16px rgba(0, 212, 255, 0.3);
        }

        /* Flip the card when class is added */
        .flip-card-inner.flipped {
            transform: rotateY(180deg);
        }

        .flip-card-front,
        .flip-card-back {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            border-radius: var(--border-radius);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            border: 2px solid var(--primary-color);
        }

        /* ============================================
           CARD FRONT (Face Down - Mysterious Card Back)
           ============================================ */
        .flip-card-front {
            background: linear-gradient(135deg, var(--card-bg) 0%, #0d0f17 100%);
            color: var(--text-light);
            flex-direction: column;
            gap: 1rem;
            position: relative;
            overflow: hidden;
        }

        /* Decorative pattern on card back */
        .flip-card-front::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                repeating-linear-gradient(
                    45deg,
                    transparent,
                    transparent 35px,
                    rgba(0, 212, 255, 0.1) 35px,
                    rgba(0, 212, 255, 0.1) 70px
                );
            pointer-events: none;
        }

        .flip-card-front-content {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.8rem;
        }

        .mystery-icon {
            font-size: 3rem;
            color: var(--primary-color);
            text-shadow: 0 0 15px rgba(0, 212, 255, 0.8);
            animation: pulse 2s ease-in-out infinite;
        }

        @@keyframes pulse {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.6;
            }
        }

        .mystery-text {
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: 1px;
            color: var(--primary-color);
            text-shadow: 0 0 10px rgba(0, 212, 255, 0.6);
        }

        .flip-hint {
            font-size: 0.85rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 0.5rem;
        }

        /* ============================================
           CARD BACK (Face Up - Content Revealed)
           ============================================ */
        .flip-card-back {
            background: linear-gradient(135deg, #00d4ff 0%, #0099cc 100%);
            color: var(--dark-bg);
            transform: rotateY(180deg);
            flex-direction: column;
            justify-content: space-between;
            padding: 1.2rem;
            font-weight: 600;
        }

        .card-kanji {
            font-size: 2.5rem;
            font-weight: 900;
            letter-spacing: 2px;
            line-height: 1;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
        }

        .card-hiragana {
            font-size: 1.2rem;
            opacity: 0.95;
            letter-spacing: 1px;
        }

        .card-meaning {
            font-size: 1rem;
            opacity: 0.9;
            line-height: 1.4;
            word-wrap: break-word;
            margin-top: 0.5rem;
        }

        /* ============================================
           HOVER EFFECTS & INTERACTIONS
           ============================================ */
        .flip-card:hover .flip-card-inner {
            box-shadow: 0 12px 24px rgba(0, 212, 255, 0.6);
            transform: scale(1.02);
        }

        .flip-card:hover .flip-card-front {
            border-color: var(--secondary-color);
        }

        .flip-card:hover .mystery-icon {
            font-size: 3.3rem;
        }

        /* ============================================
           EMPTY STATE
           ============================================ */
        .empty-state {
            text-align: center;
            padding: 3rem;
            color: var(--text-muted);
        }

        .empty-state-icon {
            font-size: 4rem;
            color: var(--primary-color);
            margin-bottom: 1rem;
            opacity: 0.6;
        }

        /* ============================================
           ACTION BUTTONS
           ============================================ */
        .action-buttons {
            display: flex;
            gap: 1rem;
            justify-content: center;
            margin-top: 2rem;
        }

        .btn-custom {
            padding: 0.75rem 2rem;
            font-size: 1rem;
            font-weight: 600;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-family: 'Orbitron', monospace;
        }

        .btn-draw {
            background-color: var(--primary-color);
            color: var(--dark-bg);
            border: 2px solid var(--primary-color);
        }

        .btn-draw:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 20px rgba(0, 212, 255, 0.6);
            background-color: var(--secondary-color);
            border-color: var(--secondary-color);
            color: var(--dark-bg);
        }

        .btn-reset {
            background-color: transparent;
            color: var(--primary-color);
            border: 2px solid var(--primary-color);
        }

        .btn-reset:hover {
            background-color: var(--primary-color);
            color: var(--dark-bg);
            box-shadow: 0 0 15px rgba(0, 212, 255, 0.4);
        }

        /* ============================================
           RESPONSIVE DESIGN
           ============================================ */
        @@media (max-width: 768px) {
            .page-title {
                font-size: 1.8rem;
            }

            .cards-grid {
                grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
                gap: 1.5rem;
            }

            .flip-card {
                height: 200px;
            }

            .card-kanji {
                font-size: 2rem;
            }

            .cards-container {
                padding: 1rem;
            }
        }

        @@media (max-width: 480px) {
            body {
                padding: 1rem 0.5rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .cards-grid {
                grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
                gap: 1rem;
            }

            .flip-card {
                height: 180px;
            }

            .card-kanji {
                font-size: 1.8rem;
            }

            .flip-card-front,
            .flip-card-back {
                padding: 1rem;
            }
        }
    </style>
</head>
<body>
    <!-- Page Header -->
    <div class="page-header">
        <div class="page-title">
            <i class="fas fa-dice"></i> 日本語 GACHA
        </div>
        <div class="page-subtitle">Today's Vocabulary Draw</div>
        <div class="draw-info">✨ Draw 5 Random Words ✨</div>
    </div>

    <!-- Main Content Container -->
    <div class="cards-container">
        @if (Model.DailyVocabulary != null && Model.DailyVocabulary.Count > 0)
        {
            <!-- Cards Grid -->
            <div class="cards-grid">
                @foreach (var vocab in Model.DailyVocabulary)
                {
                    <div class="flip-card" onclick="flipCard(this)">
                        <div class="flip-card-inner">
                            <!-- Front (Face Down) -->
                            <div class="flip-card-front">
                                <div class="flip-card-front-content">
                                    <div class="mystery-icon">
                                        <i class="fas fa-question"></i>
                                    </div>
                                    <div class="mystery-text">Mystery</div>
                                    <div class="flip-hint">Click to Reveal</div>
                                </div>
                            </div>

                            <!-- Back (Face Up - Content) -->
                            <div class="flip-card-back">
                                <div class="card-kanji">@vocab.Kanji</div>
                                <div class="card-hiragana">@vocab.Hiragana</div>
                                <div class="card-meaning">@vocab.Meaning</div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <button class="btn-custom btn-draw" onclick="location.reload()">
                    <i class="fas fa-redo"></i> Draw Again
                </button>
                <button class="btn-custom btn-reset" onclick="resetAllCards()">
                    <i class="fas fa-undo"></i> Reset Cards
                </button>
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fas fa-inbox"></i>
                </div>
                <h3>No Vocabulary Available</h3>
                <p>It looks like there's no vocabulary in the database yet.</p>
                <p style="margin-top: 1rem; font-size: 0.9rem;">
                    Please add vocabulary items to start using the Daily Draw feature.
                </p>
            </div>
        }
    </div>

    <!-- ============================================
         VANILLA JAVASCRIPT - FLIP CARD LOGIC
         ============================================ -->
    <script>
        /**
         * Flip a single card when clicked
         * cardElement - The flip-card element to flip
         */
        function flipCard(cardElement) {
            // Select the inner flip container within the clicked card
            const flipInner = cardElement.querySelector('.flip-card-inner');

            // Toggle the 'flipped' class to trigger CSS transform
            flipInner.classList.toggle('flipped');
        }

        /**
         * Reset all cards to face-down state
         * Removes the 'flipped' class from all cards
         */
        function resetAllCards() {
            // Select all flip-card-inner elements
            const allFlipInners = document.querySelectorAll('.flip-card-inner');

            // Remove 'flipped' class from each one
            allFlipInners.forEach(flipInner => {
                flipInner.classList.remove('flipped');
            });
        }

        /**
         * Optional: Allow keyboard interaction
         * Press 'R' to reset all cards
         */
        document.addEventListener('keydown', (event) => {
            if (event.key.toLowerCase() === 'r') {
                resetAllCards();
            }
        });
    </script>
</body>
</html>

