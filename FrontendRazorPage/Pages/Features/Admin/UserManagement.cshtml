@page
@model FrontendRazorPage.Pages.Features.Admin.UserManagementModel
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="users-management-container">
    <div class="page-header">
        <div class="header-left">
            <h2><i class="fa-solid fa-users-gear"></i> Quản lý người dùng</h2>
            <p>Quản lý tài khoản và phân quyền người dùng trong hệ thống</p>
        </div>
        <div class="header-right">
            <a asp-page="/Features/Admin/AdminDashboard" class="btn-back">
                <i class="fa-solid fa-arrow-left"></i> Quay lại Dashboard
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
            <i class="fa-solid @(Model.IsSuccess ? "fa-circle-check" : "fa-circle-exclamation")"></i>
            @Model.Message
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="users-table-wrapper">
        <div class="table-header">
            <div class="table-stats">
                <i class="fa-solid fa-users"></i>
                <span>Tổng số người dùng: <strong>@Model.Users.Count</strong></span>
            </div>
            <div class="table-search">
                <i class="fa-solid fa-search"></i>
                <input type="text" id="searchInput" placeholder="Tìm kiếm theo tên hoặc email..." class="search-input">
            </div>
        </div>

        <div class="table-responsive">
            <table class="user-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên người dùng</th>
                        <th>Email</th>
                        <th>Quyền</th>
                        <th>Streak</th>
                        <th>EXP</th>
                        <th>Hoạt động cuối</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody id="userTableBody">
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td class="user-id">@user.Id</td>
                            <td>
                                <div class="user-info">
                                    <div class="user-avatar">
                                        <i class="fa-solid fa-circle-user"></i>
                                    </div>
                                    <div class="user-name">@user.UserName</div>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                <span class="role-badge @(user.Role == "Admin" ? "role-admin" : "role-user")">
                                    <i class="fa-solid @(user.Role == "Admin" ? "fa-shield-haltered" : "fa-user")"></i>
                                    @user.Role
                                </span>
                            </td>
                            <td>
                                <div class="streak-badge">
                                    <i class="fa-solid fa-fire"></i>
                                    @user.CurrentStreak
                                </div>
                            </td>
                            <td>
                                <div class="exp-badge">
                                    <i class="fa-solid fa-star"></i>
                                    @user.TotalExp
                                </div>
                            </td>
                            <td>
                                @(user.LastActiveDate?.ToString("dd/MM/yyyy") ?? "Chưa hoạt động")
                            </td>
                            <td>
                                <div class="action-buttons-cell">
                                    @if (user.Role != "Admin")
                                    {
                                        <form method="post" asp-page-handler="ChangeRole" class="role-form" onsubmit="return confirm('Bạn có chắc muốn nâng cấp @user.UserName lên quyền Admin?')">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <input type="hidden" name="newRole" value="Admin" />
                                            <button type="submit" class="btn-upgrade">
                                                <i class="fa-solid fa-arrow-up"></i> Nâng cấp Admin
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="ChangeRole" class="role-form" onsubmit="return confirm('Bạn có chắc muốn hạ @user.UserName xuống quyền User?')">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <input type="hidden" name="newRole" value="User" />
                                            <button type="submit" class="btn-downgrade">
                                                <i class="fa-solid fa-arrow-down"></i> Hạ xuống User
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Users.Any())
        {
            <div class="empty-state">
                <i class="fa-solid fa-users-slash"></i>
                <p>Không có dữ liệu người dùng</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput')?.addEventListener('keyup', function() {
            const searchValue = this.value.toLowerCase();
            const rows = document.querySelectorAll('#userTableBody tr');

            rows.forEach(row => {
                const userName = row.querySelector('.user-name')?.textContent.toLowerCase() || '';
                const email = row.querySelector('td:nth-child(3)')?.textContent.toLowerCase() || '';

                if (userName.includes(searchValue) || email.includes(searchValue)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}