@page
@model FrontendRazorPage.Pages.Features.Admin.Vocabularies.CreateModel
@{
    ViewData["Title"] = "Thêm Từ Vựng Mới";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-1">Thêm Từ Vựng Mới</h2>
            <p class="text-muted mb-0">Bài học ID: <span class="badge bg-secondary">#@Model.SelectedLessonId</span></p>
        </div>
        <a asp-page="./Index" asp-route-SelectedLevelId="@Model.SelectedLevelId" asp-route-SelectedLessonId="@Model.SelectedLessonId" class="btn btn-outline-secondary fw-semibold">
            <i class="fa-solid fa-arrow-left me-2"></i>Quay lại danh sách
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 p-4 h-100" style="border-radius: 12px;">
                <h5 class="fw-bold text-dark mb-3"><i class="fa-solid fa-keyboard text-primary me-2"></i>Nhập Thủ Công</h5>
                <hr class="text-muted opacity-25 mt-0 mb-4">

                <form method="post" class="d-flex flex-column h-100">
                    <input type="hidden" asp-for="VocabularyInput.LessonId" value="@Model.SelectedLessonId" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="VocabularyInput.Kanji" class="form-label fw-semibold text-secondary">Chữ Hán (Kanji)</label>
                            <input asp-for="VocabularyInput.Kanji" class="form-control border-2" placeholder="Ví dụ: 私" style="border-radius: 8px;" />
                            <span asp-validation-for="VocabularyInput.Kanji" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="VocabularyInput.Hiragana" class="form-label fw-semibold text-secondary">Cách đọc (Hiragana) <span class="text-danger">*</span></label>
                            <input asp-for="VocabularyInput.Hiragana" class="form-control border-2" placeholder="Ví dụ: わたし" style="border-radius: 8px;" />
                            <span asp-validation-for="VocabularyInput.Hiragana" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="VocabularyInput.Romaji" class="form-label fw-semibold text-secondary">Romaji <span class="text-danger">*</span></label>
                            <input asp-for="VocabularyInput.Romaji" class="form-control border-2" placeholder="Ví dụ: watashi" style="border-radius: 8px;" />
                            <span asp-validation-for="VocabularyInput.Romaji" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="VocabularyInput.Meaning" class="form-label fw-semibold text-secondary">Ý nghĩa Tiếng Việt <span class="text-danger">*</span></label>
                            <input asp-for="VocabularyInput.Meaning" class="form-control border-2" placeholder="Ví dụ: Tôi, bản thân" style="border-radius: 8px;" />
                            <span asp-validation-for="VocabularyInput.Meaning" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="VocabularyInput.ExampleSentence" class="form-label fw-semibold text-secondary">Câu Ví Dụ </label>
                            <textarea asp-for="VocabularyInput.ExampleSentence" class="form-control border-2" rows="3" placeholder="Nhập câu ví dụ ứng dụng từ vựng này..." style="border-radius: 8px;"></textarea>
                        </div>
                    </div>

                    <div class="mt-auto pt-4">
                        <button type="submit" class="btn btn-primary fw-bold w-100 py-2 text-uppercase" style="border-radius: 8px;">
                            <i class="fa-solid fa-floppy-disk me-2"></i>Lưu Từ Vựng
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-0 p-4 h-100" style="border-radius: 12px;">
                <h5 class="fw-bold text-dark mb-3"><i class="fa-solid fa-file-csv text-success me-2"></i>Import File </h5>
                <hr class="text-muted opacity-25 mt-0 mb-4">

                <form method="post" asp-page-handler="Import" enctype="multipart/form-data" class="d-flex flex-column h-100">
                    <input type="hidden" name="lessonId" value="@Model.SelectedLessonId" />

                    <div class="upload-area p-4 text-center mb-4 flex-grow-1 d-flex flex-column justify-content-center align-items-center position-relative"
                         style="border: 2px dashed #28a745; border-radius: 12px; background-color: #f4fbf6; transition: 0.3s;">

                        <i class="fa-solid fa-cloud-arrow-up fa-4x text-success mb-3 opacity-75"></i>
                        <h6 class="fw-bold text-dark mb-1">Chọn file dữ liệu từ máy tính</h6>
                        <p class="text-muted small mb-3">Chỉ chấp nhận định dạng .csv hoặc .txt</p>

                        <input asp-for="FileUpload" type="file" class="form-control border-success shadow-sm mb-4" accept=".csv, .txt" style="border-radius: 8px; max-width: 280px;" required />

                        <div class="text-start bg-white p-3 rounded shadow-sm w-100 border border-success border-opacity-25">
                            <p class="text-dark small mb-2 fw-bold">
                                <i class="fa-solid fa-circle-info text-primary me-1"></i> Cấu trúc các cột chuẩn:
                            </p>
                            <code class="d-block bg-light p-2 rounded text-dark border font-monospace small" style="word-break: break-all;">
                                Kanji, Hiragana, Romaji, Meaning, ExampleSentence
                            </code>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-success fw-bold w-100 py-2 text-uppercase shadow-sm mt-auto" style="border-radius: 8px;">
                        <i class="fa-solid fa-file-import me-2"></i>Tiến Hành Import
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

