@page "{id:int}"
@model FrontendRazorPage.Pages.Features.Admin.Vocabularies.EditModel
@{
    ViewData["Title"] = "Chỉnh Sửa Từ Vựng";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-dark fw-bold mb-1">Chỉnh Sửa Từ Vựng</h2>
            <p class="text-muted mb-0">Đang chỉnh sửa từ vựng mã số: <code class="fs-6">#@Model.VocabularyInput.Id</code></p>
        </div>
        <a asp-page="./Index" asp-route-SelectedLevelId="@Model.SelectedLevelId" asp-route-SelectedLessonId="@Model.SelectedLessonId" class="btn btn-outline-secondary fw-semibold">
            <i class="fa-solid fa-arrow-left me-2"></i>Hủy bỏ & Quay lại
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-exclamation me-2"></i> @Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 p-4 mx-auto" style="border-radius: 12px; max-width: 800px;">
        <h5 class="fw-bold text-dark mb-3"><i class="fa-solid fa-pen-to-square text-warning me-2"></i>Thay đổi thông tin từ vựng</h5>
        <hr class="text-muted opacity-25 mt-0 mb-4">

        <form method="post">
            <input type="hidden" asp-for="SelectedLevelId" />
            <input type="hidden" asp-for="SelectedLessonId" />

            <input type="hidden" asp-for="VocabularyInput.Id" />
            <input type="hidden" asp-for="VocabularyInput.LessonId" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="VocabularyInput.Kanji" class="form-label fw-semibold text-secondary">Chữ Hán (Kanji)</label>
                    <input asp-for="VocabularyInput.Kanji" class="form-control border-2" placeholder="Ví dụ: 私" style="border-radius: 8px;" />
                    <span asp-validation-for="VocabularyInput.Kanji" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="VocabularyInput.Hiragana" class="form-label fw-semibold text-secondary">Cách đọc (Hiragana) <span class="text-danger">*</span></label>
                    <input asp-for="VocabularyInput.Hiragana" class="form-control border-2" placeholder="Ví dụ: わたし" style="border-radius: 8px;" />
                    <span asp-validation-for="VocabularyInput.Hiragana" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="VocabularyInput.Romaji" class="form-label fw-semibold text-secondary">Romaji <span class="text-danger">*</span></label>
                    <input asp-for="VocabularyInput.Romaji" class="form-control border-2" placeholder="Ví dụ: watashi" style="border-radius: 8px;" />
                    <span asp-validation-for="VocabularyInput.Romaji" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="VocabularyInput.Meaning" class="form-label fw-semibold text-secondary">Ý nghĩa Tiếng Việt <span class="text-danger">*</span></label>
                    <input asp-for="VocabularyInput.Meaning" class="form-control border-2" placeholder="Ví dụ: Tôi, bản thân" style="border-radius: 8px;" />
                    <span asp-validation-for="VocabularyInput.Meaning" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="VocabularyInput.ExampleSentence" class="form-label fw-semibold text-secondary">Câu Ví Dụ (Nếu có)</label>
                    <textarea asp-for="VocabularyInput.ExampleSentence" class="form-control border-2" rows="3" placeholder="Nhập câu ví dụ chỉnh sửa..." style="border-radius: 8px;"></textarea>
                </div>
            </div>

            <div class="mt-4 pt-2 text-end">
                <button type="submit" class="btn btn-warning fw-bold text-white px-4 py-2 text-uppercase" style="border-radius: 8px;">
                    <i class="fa-solid fa-circle-check me-2"></i>Cập Nhật Từ Vựng
                </button>
            </div>
        </form>
    </div>
</div>
