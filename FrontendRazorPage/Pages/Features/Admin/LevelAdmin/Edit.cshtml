@page "{id:int}"
@model FrontendRazorPage.Pages.Features.Admin.Levels.EditModel
@{
    ViewData["Title"] = "Cập nhật cấp độ";
    
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow-sm p-4">
        <h4 class="text-warning mb-3">📝 Cập Nhật Cấp Độ</h4>
        <hr />
        <form method="post">
            <input type="hidden" asp-for="InputLevel.Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label fw-bold">Tên cấp độ</label>
                <input type="text" class="form-control" asp-for="InputLevel.Name" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả chi tiết</label>
                <textarea class="form-control" rows="3" asp-for="InputLevel.Description"></textarea>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-page="./Index" class="btn btn-secondary">Hủy bỏ</a>
                <button type="submit" class="btn btn-warning px-4">Cập nhật</button>
            </div>
        </form>
    </div>
</div>