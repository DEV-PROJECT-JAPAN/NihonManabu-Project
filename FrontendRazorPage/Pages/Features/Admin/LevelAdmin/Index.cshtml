@page
@model FrontendRazorPage.Pages.Features.Admin.Levels.IndexModel
@{
    ViewData["Title"] = "Danh sách cấp độ";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>QUẢN LÝ CẤP ĐỘ TIẾNG NHẬT</h2>
        <a asp-page="./Create" class="btn btn-primary">➕ Thêm Cấp Độ Mới</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @Model.Message
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 10%">ID</th>
                    <th style="width: 20%">Tên Mức Độ</th>
                    <th>Mô Tả</th>
                    <th style="width: 18%">Ngày Tạo</th>
                    <th style="width: 18%">Ngày Cập Nhật</th>
                    <th style="width: 15%" class="text-center">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Levels)
                {
                    <tr>
                        <td><code>#@item.Id</code></td>
                        <td><span class="badge bg-primary fs-6">@item.Name</span></td>
                        <td>@item.Description</td>
                        <td class="text-muted">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-muted">@item.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</td> 
                        <td>
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>

                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Bạn có chắc chắn muốn xóa?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>