@page
@model FrontendRazorPage.Pages.Features.Admin.Levels.CreateModel
@{
    ViewData["Title"] = "Thêm cấp độ mới";

}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow-sm p-4">
        <h4 class="text-success mb-3">➕ Thêm Cấp Độ Mới</h4>
        <hr />
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label fw-bold">Tên cấp độ</label>
                <input type="text" class="form-control" placeholder="Ví dụ: N5, N4..." asp-for="InputLevel.Name" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả chi tiết</label>
                <textarea class="form-control" rows="3" placeholder="Nhập mô tả..." asp-for="InputLevel.Description"></textarea>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-page="./Index" class="btn btn-secondary">Hủy bỏ</a>
                <button type="submit" class="btn btn-success px-4">Lưu lại</button>
            </div>
        </form>
    </div>
</div>