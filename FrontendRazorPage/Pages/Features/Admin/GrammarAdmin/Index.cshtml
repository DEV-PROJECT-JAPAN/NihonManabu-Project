@page
@model FrontendRazorPage.Pages.Features.Admin.GrammarAdmin.IndexModel
@{
    ViewData["Title"] = "Quản lý Ngữ Pháp";
    Layout = "_LayoutAdmin";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-dark m-0">QUẢN LÝ MẪU NGỮ PHÁP</h2>
        <a asp-page="./Create" asp-route-lessonId="@Model.SelectedLessonId" class="btn btn-primary shadow-sm" style="background-color: #ff9f43; border-color: #ff9f43; font-weight: 600;">
            ➕ Thêm Ngữ Pháp Mới
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
            @Model.Message
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 mb-4 bg-light" style="border-radius: 8px;">
        <div class="card-body py-3">
            <form method="get" class="row align-items-center g-3">

                <div class="col-md-4">
                    <label class="fw-semibold text-secondary small d-block mb-1">
                        <i class="bi bi-filter me-1"></i> Bước 1: Chọn Cấp Độ
                    </label>
                    <select asp-for="SelectedLevelId" class="form-select border-2" onchange="window.location.href='?SelectedLevelId=' + this.value" style="border-radius: 8px; font-size: 0.9rem;">
                        <option value="">-- Chọn Cấp Độ --</option>
                        @foreach (var lvl in Model.Levels)
                        {
                            <option value="@lvl.Id">@lvl.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-5">
                    <label class="fw-semibold text-secondary small d-block mb-1">
                        <i class="bi bi-book-open me-1"></i> Bước 2: Chọn Bài Học
                    </label>
                    <select asp-for="SelectedLessonId" class="form-select border-2" onchange="this.form.submit()" style="border-radius: 8px; font-size: 0.9rem;" disabled="@(Model.SelectedLevelId == null || !Model.Lessons.Any())">
                        <option value="">-- Chọn Bài Học --</option>
                        @foreach (var les in Model.Lessons)
                        {
                            <option value="@les.Id">Bài @les.Order: @les.Title</option>
                        }
                    </select>
                </div>

            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <table class="table table-hover table-striped mb-0 align-middle bg-white">
            <thead class="table-dark text-uppercase fs-7">
                <tr>
                    <th style="width: 7%">ID</th>
                    <th style="width: 25%">Cấu Trúc Ngữ Pháp</th>
                    <th style="width: 38%">Giải Thích Chi Tiết</th>
                    <th style="width: 10%">Ngày Tạo</th>
                    <th style="width: 10%">Cập Nhật</th>
                    <th style="width: 10%">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.SelectedLessonId == null || Model.SelectedLessonId == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            <i class="bi bi-hand-index-thumb text-warning fs-2 d-block mb-2 opacity-75"></i>
                            Vui lòng chọn cụ thể một <b>Cấp độ</b> và <b>Bài học</b> ở trên để xem danh sách cấu trúc ngữ pháp.
                        </td>
                    </tr>
                }
                else if (!Model.Grammars.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            <i class="bi bi-folder-open fs-2 d-block mb-2 text-secondary opacity-50"></i>
                            Bài học này hiện tại chưa có mẫu ngữ pháp nào. Bạn hãy bấm nút thêm mới nhé!
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.Grammars)
                    {
                        <tr>
                            <td><code>#@item.Id</code></td>
                            <td>
                                <span class="text-dark fw-bold font-monospace" style="font-size: 0.95rem;">@item.Structure</span>
                            </td>
                            <td>
                                <div class="text-secondary small" style="max-width: 500px; white-space: pre-line;">
                                    @item.Explanation
                                </div>
                            </td>
                            <td class="text-muted small">
                                @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="text-secondary small fw-medium">
                                @(item.UpdatedAt != null ? item.UpdatedAt.ToString("dd/MM/yyyy HH:mm") : "---")
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm fw-semibold text-white px-2" style="border-radius: 6px;">Sửa</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Khôi có chắc chắn muốn xóa mẫu ngữ pháp này vĩnh viễn khỏi Database?');">
                                        <input type="hidden" name="SelectedLevelId" value="@Model.SelectedLevelId" />
                                        <input type="hidden" name="SelectedLessonId" value="@Model.SelectedLessonId" />
                                        <button type="submit" class="btn btn-danger btn-sm fw-semibold px-2" style="border-radius: 6px;">Xóa</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    body {
        background-color: #f4f6f9 !important;
    }

    .fs-7 {
        font-size: 0.8rem !important;
    }

    tbody td {
        padding: 0.85rem 0.75rem !important;
        font-size: 0.9rem;
    }
</style>