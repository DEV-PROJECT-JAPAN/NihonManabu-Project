@page "{id:int}"
@model FrontendRazorPage.Pages.Features.Admin.GrammarAdmin.EditModel
@{
    ViewData["Title"] = "Chỉnh sửa Ngữ Pháp";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container d-flex flex-column justify-content-center align-items-center min-vh-100 py-5">
    <div class="row w-100 justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="mb-3">
                <a asp-page="./Index" class="text-decoration-none text-muted small hover-dark flex-inline align-items-center">
                    <i class="bi bi-arrow-left me-1"></i> Trở về danh sách ngữ pháp
                </a>
            </div>

            <div class="card shadow border-0 rounded-4 overflow-hidden bg-white">

                <div class="card-header bg-white p-4 border-bottom border-light">
                    <h5 class="card-title mb-0 fw-bold d-flex align-items-center text-dark">
                        <span class="p-2 bg-warning-subtle rounded-3 text-warning me-3 d-flex align-items-center justify-content-center">
                            <i class="bi bi-pencil-square fs-5"></i>
                        </span>
                        Chỉnh Sửa Mẫu Ngữ Pháp
                    </h5>
                    <p class="text-muted small mb-0 mt-2 ms-5">Cập nhật nội dung thực thể gốc (ID bản ghi: #@Model.Grammar.Id)</p>
                </div>

                <div class="card-body p-4">
                    <form method="post" autocomplete="off">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        <input type="hidden" asp-for="Grammar.Id" />

                        <div class="form-group mb-4">
                            <label asp-for="Grammar.LessonId" class="form-label">ID Bài Học</label>
                            <div class="input-group custom-input-group">
                                <span class="input-group-text"><i class="bi bi-hash text-muted"></i></span>
                                <input asp-for="Grammar.LessonId" class="form-control" type="number" placeholder="Nhập số ID bài học..." required />
                            </div>
                            <span asp-validation-for="Grammar.LessonId" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Grammar.Structure" class="form-label">Cấu Trúc Ngữ Pháp</label>
                            <div class="input-group custom-input-group">
                                <span class="input-group-text"><i class="bi bi-spellcheck text-muted"></i></span>
                                <input asp-for="Grammar.Structure" class="form-control" placeholder="Nhập mẫu cấu trúc..." required />
                            </div>
                            <span asp-validation-for="Grammar.Structure" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Grammar.Explanation" class="form-label">Giải Thích Ý Nghĩa & Ngữ Cảnh</label>
                            <textarea asp-for="Grammar.Explanation" class="form-control custom-textarea" rows="5" placeholder="Cập nhật giải thích chi tiết..." required></textarea>
                            <span asp-validation-for="Grammar.Explanation" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="bg-light p-3 rounded-3 mb-4 border border-light-subtle">
                            <div class="row text-secondary g-2" style="font-size: 0.8rem; letter-spacing: 0.2px;">
                                <div class="col-sm-6">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-calendar-plus text-muted me-2 fs-6"></i>
                                        <div>
                                            <span class="d-block text-muted" style="font-size: 0.7rem; text-uppercase: none;">Ngày tạo ban đầu</span>
                                            <span class="fw-semibold text-dark">@Model.Grammar.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6 border-start-custom">
                                    <div class="d-flex align-items-center ps-sm-3">
                                        <i class="bi bi-calendar-check text-muted me-2 fs-6"></i>
                                        <div>
                                            <span class="d-block text-muted" style="font-size: 0.7rem; text-uppercase: none;">Cập nhật hệ thống</span>
                                            <span class="fw-semibold text-dark">@Model.Grammar.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end border-top border-light pt-4">
                            <a asp-page="./Index" class="btn btn-muted-custom px-4">
                                Hủy thay đổi
                            </a>
                            <button type="submit" class="btn btn-warning-custom px-4 shadow-sm">
                                <i class="bi bi-cloud-check-fill me-1"></i> Cập Nhật Hệ Thống
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    body {
        background-color: #f4f6f9 !important; /* Màu nền xám nhẹ đồng bộ hệ thống */
    }

    /* Ép căn chỉnh min-vh-100 loại trừ khoảng cách nếu có dính Navbar */
    .min-vh-100 {
        min-height: calc(100vh - 40px) !important;
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }

    .rounded-3 {
        border-radius: 0.6rem !important;
    }

    /* Thiết kế lại nhãn chữ Label */
    .form-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #495057;
        margin-bottom: 0.5rem;
        letter-spacing: 0.3px;
    }

    /* Input Group phẳng viền mượt mờ */
    .custom-input-group {
        border: 1px solid #dee2e6;
        border-radius: 0.5rem;
        overflow: hidden;
        transition: all 0.2s ease-in-out;
        background-color: #ffffff;
    }

        .custom-input-group .input-group-text {
            background-color: transparent;
            border: none;
            padding-left: 1rem;
            padding-right: 0.5rem;
        }

        .custom-input-group .form-control {
            border: none;
            padding: 0.65rem 1rem 0.65rem 0.5rem;
            font-size: 0.95rem;
        }

            .custom-input-group .form-control:focus {
                box-shadow: none;
                background-color: #ffffff;
            }
        /* Hiệu ứng focus đồng bộ màu hổ phách ấm áp của nút Sửa */
        .custom-input-group:focus-within {
            border-color: #ffc107;
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.15);
        }

    /* Cấu hình vùng Textarea nhập văn bản */
    .custom-textarea {
        border: 1px solid #dee2e6;
        border-radius: 0.5rem;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        transition: all 0.2s ease-in-out;
        resize: vertical;
    }

        .custom-textarea:focus {
            border-color: #ffc107;
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.15);
        }

    /* Vạch kẻ dọc phân chia khối thời gian */
    @@media (min-width: 576px) {
        .border-start-custom {
            border-left: 1px solid #dee2e6 !important;
        }
    }

    /* Nút Cập nhật màu vàng hổ phách tinh tế */
    .btn-warning-custom {
        background-color: #ffc107;
        color: #000000;
        font-weight: 600;
        font-size: 0.9rem;
        border: none;
        border-radius: 0.5rem;
        padding: 0.6rem 1.5rem;
        transition: all 0.2s;
    }

        .btn-warning-custom:hover {
            background-color: #e0a800;
            color: #000000;
            transform: translateY(-1px);
        }

    /* Nút Hủy bỏ thanh lịch màu xám sáng */
    .btn-muted-custom {
        background-color: #e9ecef;
        color: #495057;
        font-weight: 600;
        font-size: 0.9rem;
        border: none;
        border-radius: 0.5rem;
        padding: 0.6rem 1.5rem;
        transition: all 0.2s;
    }

        .btn-muted-custom:hover {
            background-color: #dee2e6;
            color: #212529;
        }

    .hover-dark:hover {
        color: #212529 !important;
    }

    /* Màu nền nhạt dán cho Icon Header */
    .bg-warning-subtle {
        background-color: rgba(255, 193, 7, 0.12) !important;
    }
</style>