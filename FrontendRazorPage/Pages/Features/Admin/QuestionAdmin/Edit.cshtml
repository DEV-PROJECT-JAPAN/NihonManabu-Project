@page "{id:int}/{handler?}"
@model FrontendRazorPage.Pages.Features.Admin.QuestionAdmin.EditModel
@{
    ViewData["Title"] = "Chỉnh Sửa Câu Hỏi";
}

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var tokens = Antiforgery.GetAndStoreTokens(HttpContext);
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container-fluid py-4 px-4">
    <div class="mb-3">
        <a asp-page="./Index"
           asp-route-SelectedLevelId="@Model.SelectedLevelId"
           asp-route-SelectedLessonId="@Model.SelectedLessonId"
           class="text-decoration-none text-muted small hover-dark">
            <i class="bi bi-arrow-left me-1"></i> Quay về ngân hàng câu hỏi bài học
        </a>
    </div>

    <div id="jsErrorAlert" class="alert alert-danger shadow-sm border-0 mb-4 rounded-3 d-none">
        <i class="bi bi-exclamation-octagon-fill me-2"></i>
        <strong>Lỗi hệ thống:</strong> <span id="errorText"></span>
    </div>

    <form id="questionForm" autocomplete="off" onsubmit="handleFormSubmitViaJson(event); return false;">
        @Html.AntiForgeryToken()

        <input type="hidden" id="questionId" value="@Model.Question.Id" />

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="card shadow-sm border-0 p-4 bg-white" style="border-radius: 12px;">
                    <h5 class="fw-bold text-dark mb-0 d-flex align-items-center">
                        <span class="p-2 bg-warning-subtle rounded-3 text-warning me-3 d-flex align-items-center justify-content-center"
                              style="width: 38px; height: 38px;">
                            <i class="bi bi-pencil-square fs-5"></i>
                        </span>
                        Chỉnh Sửa Nội Dung Câu Hỏi
                        <span class="badge bg-secondary ms-auto font-monospace" style="font-size: 0.75rem;">
                            ID #@Model.Question.Id
                        </span>
                    </h5>
                    <hr class="opacity-25 my-4">

                    <div class="form-group mb-4">
                        <label class="form-label fw-bold text-secondary small mb-2">Phân loại thể thức</label>
                        <select id="questionTypeSelect"
                                class="form-select custom-control"
                                onchange="handleQuestionTypeChange(this.value)">
                            @if (Model.Question.QuestionType == 1)
                            {
                                <option value="1" selected>Trắc nghiệm chọn đáp án đúng</option>
                                <option value="2">Sắp xếp các từ thành câu hoàn chỉnh</option>
                            }
                            else
                            {
                                <option value="1">Trắc nghiệm chọn đáp án đúng</option>
                                <option value="2" selected>Sắp xếp các từ thành câu hoàn chỉnh</option>
                            }
                        </select>
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label fw-bold text-secondary small mb-2">
                            Liên kết cấu trúc ngữ pháp mẫu
                        </label>
                        <select id="grammarSelect" class="form-select custom-control" required>
                            <option value="">-- Chọn Mẫu Ngữ Pháp Đối Chiếu --</option>
                            @foreach (var g in Model.Grammars)
                            {
                                <option value="@g.Id" selected="@(Model.Question.GrammarId == g.Id ? "selected" : null)">
                                    #@g.Id: @g.Structure
                                </option>
                            }
                        </select>
                    </div>

                    <div class="form-group mb-0">
                        <label class="form-label fw-bold text-secondary small mb-2">
                            Đề bài / Nội dung văn bản câu hỏi
                        </label>
                        <textarea id="contentTextArea"
                                  class="form-control custom-textarea"
                                  rows="6"
                                  placeholder="Nhập đề bài tại đây..."
                                  required>@Model.Question.Content</textarea>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card shadow-sm border-0 p-4 bg-white" style="border-radius: 12px; min-height: 100%;">
                    <div class="d-flex justify-content-between align-items-center mb-0">
                        <h5 class="fw-bold text-dark m-0 d-flex align-items-center">
                            <span class="p-2 bg-success-subtle rounded-3 text-success me-3 d-flex align-items-center justify-content-center"
                                  style="width: 38px; height: 38px;">
                                <i class="bi bi-list-check fs-5"></i>
                            </span>
                            Chỉnh Sửa Khung Đáp Án
                        </h5>
                        <button type="button"
                                class="btn btn-sm btn-success-custom fw-bold px-3"
                                onclick="addAnswerRow()">
                            ➕ Thêm Dòng
                        </button>
                    </div>
                    <hr class="opacity-25 my-4">

                    <div id="typeHint" class="alert alert-info py-2.5 px-3 small border-0 mb-4" style="border-radius: 8px;"></div>

                    <div id="answersContainer">
                        @for (int i = 0; i < Model.Question.Answers.Count; i++)
                        {
                            var ans = Model.Question.Answers[i];
                            <div class="row g-2 align-items-center mb-3 answer-row">
                                <div class="col-auto">
                                    <span class="badge bg-secondary px-2 py-2 row-label font-monospace"
                                          style="min-width: 38px; font-size: 0.85rem;">@(i + 1)</span>
                                </div>
                                <div class="col">
                                    <input type="hidden" class="input-answer-id" value="@ans.Id" />
                                    <input type="text"
                                           class="form-control custom-control input-text"
                                           value="@ans.Text"
                                           placeholder="Nhập văn bản lựa chọn..."
                                           required />
                                </div>
                                <div class="col-auto text-center switch-container">
                                    <div class="form-check form-switch pt-1">
                                        <input type="hidden" class="input-iscorrect" value="@ans.IsCorrect.ToString().ToLower()" />
                                        <input type="checkbox"
                                               class="form-check-input check-iscorrect"
                                               style="transform: scale(1.2); cursor: pointer;"
                                               onclick="handleSwitchToggle(this)"
                                               @(ans.IsCorrect ? "checked" : "") />
                                        <label class="form-check-label small text-muted ms-2 label-status">
                                            @(ans.IsCorrect ? "Đúng" : "Sai")
                                        </label>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <button type="button"
                                            class="btn btn-outline-danger border-0 btn-sm p-2"
                                            onclick="removeAnswerRow(this)">
                                        <i class="bi bi-trash3-fill fs-5"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-5 pt-3 border-top border-light d-flex justify-content-end gap-2">
                        <a asp-page="./Index"
                           asp-route-SelectedLevelId="@Model.SelectedLevelId"
                           asp-route-SelectedLessonId="@Model.SelectedLessonId"
                           class="btn btn-muted-custom fw-semibold px-4">
                            Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-warning-custom fw-bold px-4 text-uppercase">
                            <i class="bi bi-cloud-arrow-up-fill me-2"></i> Lưu Thay Đổi
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    function reIndexAnswers() {
        const rows = document.querySelectorAll("#answersContainer .answer-row");
        const qType = document.getElementById("questionTypeSelect").value;

        rows.forEach((row, index) => {
            row.querySelector(".row-label").innerText = index + 1;

            if (qType === "2") {
                row.querySelector(".input-iscorrect").value = "true";
                const chk = row.querySelector(".check-iscorrect");
                if (chk) chk.checked = true;
                const label = row.querySelector(".label-status");
                if (label) label.innerText = "Đúng";
            }
        });
    }

    function handleQuestionTypeChange(typeValue) {
        const hint = document.getElementById("typeHint");
        const switchContainers = document.querySelectorAll(".switch-container");

        if (typeValue === "2") {
            hint.className = "alert alert-warning py-2.5 px-3 small border-0 mb-4";
            hint.innerHTML = `<i class="bi bi-exclamation-triangle-fill me-1"></i> Đối với <b>Sắp xếp câu</b>: Nhập các từ rời rạc theo đúng thứ tự từ trên xuống dưới.`;
            switchContainers.forEach(c => { c.style.pointerEvents = "none"; c.style.opacity = "0.5"; });
        } else {
            hint.className = "alert alert-info py-2.5 px-3 small border-0 mb-4";
            hint.innerHTML = `<i class="bi bi-info-circle-fill me-1"></i> Đối với <b>Trắc nghiệm</b>: Gạt bật duy nhất 1 công tắc thành Đúng làm đáp án chuẩn.`;
            switchContainers.forEach(c => { c.style.pointerEvents = "auto"; c.style.opacity = "1"; });
        }
        reIndexAnswers();
    }

    function addAnswerRow() {
        const container = document.getElementById("answersContainer");
        const newRow = document.createElement("div");
        newRow.className = "row g-2 align-items-center mb-3 answer-row";
        newRow.innerHTML = `
            <div class="col-auto">
                <span class="badge bg-secondary px-2 py-2 row-label font-monospace" style="min-width: 38px; font-size: 0.85rem;">1</span>
            </div>
            <div class="col">
                <input type="hidden" class="input-answer-id" value="0" />
                <input type="text" class="form-control custom-control input-text" placeholder="Nhập phương án..." required />
            </div>
            <div class="col-auto text-center switch-container">
                <div class="form-check form-switch pt-1">
                    <input type="hidden" class="input-iscorrect" value="false" />
                    <input type="checkbox" class="form-check-input check-iscorrect" style="transform: scale(1.2); cursor: pointer;" onclick="handleSwitchToggle(this)" />
                    <label class="form-check-label small text-muted ms-2 label-status">Sai</label>
                </div>
            </div>
            <div class="col-auto">
                <button type="button" class="btn btn-outline-danger border-0 btn-sm p-2" onclick="removeAnswerRow(this)">
                    <i class="bi bi-trash3-fill fs-5"></i>
                </button>
            </div>
        `;
        container.appendChild(newRow);

        if (document.getElementById("questionTypeSelect").value === "2") {
            const sc = newRow.querySelector(".switch-container");
            sc.style.pointerEvents = "none";
            sc.style.opacity = "0.5";
        }
        reIndexAnswers();
    }

    function removeAnswerRow(btn) {
        const container = document.getElementById("answersContainer");
        if (container.querySelectorAll(".answer-row").length <= 1) {
            alert("Phải có tối thiểu 1 dòng đáp án.");
            return;
        }
        btn.closest(".answer-row").remove();
        reIndexAnswers();
    }

    function handleSwitchToggle(chk) {
        if (document.getElementById("questionTypeSelect").value === "1") {
            const rows = document.querySelectorAll("#answersContainer .answer-row");
            rows.forEach(row => {
                const rowChk = row.querySelector(".check-iscorrect");
                const rowHidden = row.querySelector(".input-iscorrect");
                const rowLabel = row.querySelector(".label-status");

                if (rowChk !== chk) {
                    rowChk.checked = false;
                    rowHidden.value = "false";
                    if (rowLabel) rowLabel.innerText = "Sai";
                } else {
                    rowHidden.value = chk.checked ? "true" : "false";
                    if (rowLabel) rowLabel.innerText = chk.checked ? "Đúng" : "Sai";
                }
            });
        }
    }

    function handleFormSubmitViaJson(event) {
        if (event) event.preventDefault();

        const qType = document.getElementById("questionTypeSelect").value;
        const errorAlert = document.getElementById("jsErrorAlert");
        errorAlert.classList.add("d-none");

        if (qType === "1") {
            const hiddenInputs = document.querySelectorAll(".input-iscorrect");
            let hasTrue = false;
            hiddenInputs.forEach(input => { if (input.value === "true") hasTrue = true; });
            if (!hasTrue) {
                alert("Vui lòng gạt chọn duy nhất 1 đáp án thành [Đúng]!");
                return false;
            }
        }

        const questionId = parseInt(document.getElementById("questionId").value) || 0;

        const finalJsonData = {
            id: questionId,
            grammarId: parseInt(document.getElementById("grammarSelect").value) || 0,
            content: document.getElementById("contentTextArea").value || "",
            questionType: parseInt(qType) || 1,
            answers: []
        };

        const rows = document.querySelectorAll("#answersContainer .answer-row");
        rows.forEach((row, index) => {
            finalJsonData.answers.push({
                id: parseInt(row.querySelector(".input-answer-id").value) || 0,
                text: row.querySelector(".input-text").value || "",
                isCorrect: row.querySelector(".input-iscorrect").value === "true",
                displayOrder: (index + 1).toString()
            });
        });

        // ĐÃ ĐỒNG BỘ: Định tuyến chuẩn xác theo handler khớp với Backend cấu hình custom page route
           // Đã sửa thành UpdateQuestion
    fetch("?handler=UpdateQuestion", {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]')?.value || "@tokens.RequestToken"
        },
        body: JSON.stringify(finalJsonData)
    })
        .then(async response => {
            const responseText = await response.text();
            if (response.ok) {
                const timestamp = new Date().getTime();
                window.location.href = `../Index?SelectedLevelId=@Model.SelectedLevelId&SelectedLessonId=@Model.SelectedLessonId&timestamp=${timestamp}`;
            } else {
                try {
                    const errJson = JSON.parse(responseText);
                    throw new Error(errJson.message || "Lỗi cấu trúc dữ liệu gửi đến API.");
                } catch (e) {
                    throw new Error(responseText || "Lỗi hệ thống không xác định.");
                }
            }
        })
        .catch(error => {
            document.getElementById("errorText").innerText = error.message;
            errorAlert.classList.remove("d-none");
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        return false;
    }

    document.addEventListener("DOMContentLoaded", function () {
        handleQuestionTypeChange(document.getElementById("questionTypeSelect").value);
    });
</script>

<style>
    body {
        background-color: #f4f6f9 !important;
    }

    .hover-dark:hover {
        color: #212529 !important;
    }

    .bg-primary-subtle {
        background-color: rgba(78, 115, 223, 0.1) !important;
    }

    .bg-success-subtle {
        background-color: rgba(25, 135, 84, 0.1) !important;
    }

    .bg-warning-subtle {
        background-color: rgba(255, 193, 7, 0.15) !important;
    }

    .custom-control, .custom-textarea {
        border: 1px solid #dee2e6 !important;
        border-radius: 0.5rem !important;
        padding: 0.6rem 0.75rem !important;
        font-size: 0.9rem !important;
        color: #334155 !important;
    }

        .custom-control:focus, .custom-textarea:focus {
            border-color: #f6c23e !important;
            box-shadow: 0 0 0 0.25rem rgba(246, 194, 62, 0.2) !important;
            outline: none;
        }

    .btn-success-custom {
        background-color: #198754;
        color: #fff;
        font-weight: 600;
        font-size: 0.8rem;
        border: none;
        border-radius: 6px;
        padding: 0.45rem 1rem;
        transition: all 0.2s;
    }

    .btn-warning-custom {
        background-color: #f6c23e;
        color: #212529;
        font-weight: 700;
        font-size: 0.9rem;
        border: none;
        border-radius: 0.5rem;
        padding: 0.6rem 1.5rem;
        transition: all 0.2s;
    }

        .btn-warning-custom:hover {
            background-color: #e0a800;
            transform: translateY(-1px);
        }

    .btn-muted-custom {
        background-color: #e9ecef;
        color: #495057;
        font-weight: 600;
        font-size: 0.9rem;
        border: none;
        border-radius: 0.5rem;
        padding: 0.6rem 1.5rem;
        transition: all 0.2s;
    }
</style>
