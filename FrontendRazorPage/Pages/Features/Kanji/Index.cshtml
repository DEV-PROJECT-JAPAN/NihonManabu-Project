        // Tìm toàn bộ các thẻ <path> nằm trong nhóm nét vẽ của cấu trúc SVG KanjiVG
        const paths = svgEl.querySelectorAll('g[id^="kvg:StrokePaths"] path');

        paths.forEach(p => {
            const len = p.getTotalLength(); // Lấy độ dài thực tế (đơn vị pixel) của nét vẽ hiện tại
            p.style.transition = 'none';    // Tạm thời tắt mọi hiệu ứng chuyển động mượt
            p.style.strokeDasharray = len;  // Biến nét vẽ liền mạch thành một chuỗi đứt đoạn có khoảng trống bằng đúng chiều dài nét
            p.style.strokeDashoffset = len; // Đẩy toàn bộ nét vẽ ra khỏi vùng hiển thị (Làm nét vẽ trở nên vô hình)
        });

        // Sử dụng kỹ thuật RequestAnimationFrame đúp để ép Trình duyệt thực hiện render trạng thái ẩn trước,
        // sau đó mới áp dụng hiệu ứng chuyển động mượt mà tránh hiện tượng giật lag hình.
        requestAnimationFrame(() => {
            requestAnimationFrame(() => {
                paths.forEach((p, i) => {
                    // Đặt thời gian vẽ mỗi nét là 0.5 giây. Các nét sau sẽ đợi nét trước vẽ xong mới vẽ tiếp nhờ độ trễ tăng dần: ${i * 0.55}s
                    p.style.transition = `stroke-dashoffset 0.5s ease-in-out ${i * 0.55}s`;
                    p.style.strokeDashoffset = '0'; // Kéo nét vẽ quay trở lại vị trí ban đầu (Tạo hiệu ứng giống như đang có cây bút vẽ từ từ ra nét chữ)
                });
            });
        });
    }

