@page
@model FrontendRazorPage.Pages.Features.Grammar.IndexModel
@{
    ViewData["Title"] = "Luyện Tập Ngữ Pháp Tiếng Nhật";
}

<style>
    :root {
        --primary-color: #3B82F6;
        --primary-light: rgba(59, 130, 246, 0.12);
        --primary-glow: rgba(59, 130, 246, 0.3);
        --card-bg: #1E293B;
        --text-main: #F1F5F9;
        --text-muted: #94A3B8;
        --border-color: #334155;
        --bg-inner: #0F172A;
        --success-color: #10B981;
        --success-light: rgba(16, 185, 129, 0.15);
        --danger-color: #EF4444;
        --danger-light: rgba(239, 68, 68, 0.15);
        /* Chế độ bài tập */
        --mode-quiz: #3B82F6;
        --mode-arrange: #10B981;
        --mode-all: #8B5CF6;
    }

    body {
        background-color: #0F172A;
        color: var(--text-main);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    /* Thẻ Card Tổng Thể Cao Cấp */
    .custom-card {
        border: 1px solid var(--border-color) !important;
        border-radius: 20px !important;
        background: linear-gradient(145deg, #1E293B, #131C2E) !important;
        overflow: hidden;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
    }

        .custom-card .card-header {
            background: rgba(255, 255, 255, 0.03) !important;
            border-bottom: 1px solid var(--border-color) !important;
            padding: 20px 26px;
            font-weight: 700;
            font-size: 16px;
            letter-spacing: 0.5px;
            color: var(--text-main) !important;
        }

    /* THANH BREADCRUMB TINH CHỈNH GỌN GÀNG */
    .custom-breadcrumb {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
        background: #172033;
        border: 1px solid var(--border-color);
        padding: 14px 24px;
        border-radius: 14px;
        margin-bottom: 28px;
    }

    .breadcrumb-step {
        display: flex;
        align-items: center;
        font-size: 14px;
        font-weight: 600;
        color: var(--text-muted);
        text-decoration: none !important;
        transition: all 0.2s ease;
    }

        .breadcrumb-step:hover:not(.active-step) {
            color: var(--primary-color);
        }

        .breadcrumb-step.active-step {
            color: #FFFFFF;
            background: var(--primary-light);
            padding: 6px 14px;
            border-radius: 8px;
            border: 1px solid rgba(59, 130, 246, 0.25);
        }

    .breadcrumb-separator {
        color: var(--border-color);
        font-size: 12px;
    }

    /* TẦNG 1: THIẾT KẾ CARD LEVEL ĐẲNG CẤP */
    .level-layout-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 20px;
        padding: 10px 0;
    }

    .level-modern-btn {
        background: linear-gradient(135deg, #243149, #1A2436);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 26px 20px;
        text-align: center;
        color: var(--text-main);
        text-decoration: none !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }

        .level-modern-btn .lvl-badge {
            font-size: 24px;
            font-weight: 800;
            background: linear-gradient(135deg, #60A5FA, #3B82F6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .level-modern-btn .lvl-status {
            font-size: 13px;
            font-weight: 500;
            color: var(--text-muted);
        }

        .level-modern-btn:hover {
            border-color: var(--primary-color);
            box-shadow: 0 8px 24px rgba(59, 130, 246, 0.25);
            transform: translateY(-4px);
            background: linear-gradient(135deg, #2B3B59, #1E293F);
        }

    /* TẦNG 2 + 3: KHỐI CHỌN BÀI HỌC DẠNG DASHBOARD GRID */
    .lesson-modern-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(95px, 1fr));
        gap: 14px;
        padding: 10px 0;
    }

    .lesson-modern-item {
        background: #1E293B;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 18px 10px;
        text-align: center;
        text-decoration: none !important;
        transition: all 0.25s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

        .lesson-modern-item .number {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-main);
        }

        .lesson-modern-item .sub-text {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 2px;
            text-transform: uppercase;
        }

        .lesson-modern-item:hover {
            border-color: var(--success-color);
            background: var(--success-light);
            box-shadow: 0 6px 16px rgba(16, 185, 129, 0.15);
            transform: scale(1.03);
        }

            .lesson-modern-item:hover .number {
                color: var(--success-color);
            }

    /* TẦNG 4: DANH SÁCH NGỮ PHÁP TINH TẾ */
    .grammar-modern-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .grammar-modern-row {
        background: rgba(255, 255, 255, 0.01);
        border: 1px solid var(--border-color);
        border-radius: 14px;
        padding: 18px 24px;
        color: var(--text-main);
        font-weight: 600;
        font-size: 15px;
        text-decoration: none !important;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .grammar-modern-row:hover {
            border-color: var(--danger-color);
            background: var(--danger-light);
            color: #FCA5A5;
            transform: translateX(6px);
        }

    /* TẦNG 5: ĐẬM CHẤT DESIGN KHỐI HIỂN THỊ KIẾN THỨC CỐT LÕI */
    .knowledge-premium-box {
        background: #1E293B;
        border: 1px solid var(--border-color);
        border-radius: 20px;
        overflow: hidden;
        margin-bottom: 28px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    .knowledge-banner {
        background: linear-gradient(90deg, #1E40AF, #3B82F6);
        padding: 14px 24px;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #FFFFFF;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .knowledge-body {
        padding: 28px;
    }

    .grammar-main-title {
        font-size: 26px;
        font-weight: 800;
        color: #FFFFFF;
        letter-spacing: -0.5px;
        margin-bottom: 20px;
        display: inline-block;
        padding-bottom: 6px;
        border-bottom: 3px solid var(--primary-color);
    }

    .explanation-inner-card {
        background-color: var(--bg-inner);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 20px;
    }

    /* 3 Card Mode Lựa chọn bài tập */
    .mode-selection-container {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 24px;
    }

    @@media (max-width: 768px) {
        .mode-selection-container {
            grid-template-columns: 1fr;
        }
    }

    .mode-card {
        background: linear-gradient(145deg, #1E293B, #151F32);
        border: 2px solid var(--border-color);
        border-radius: 20px;
        padding: 35px 20px;
        text-align: center;
        text-decoration: none !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

        .mode-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
        }

    .mode-quiz::before {
        background: var(--mode-quiz);
    }

    .mode-quiz .mode-icon {
        color: var(--mode-quiz);
        background: rgba(59, 130, 246, 0.1);
    }

    .mode-quiz:hover {
        border-color: var(--mode-quiz);
        box-shadow: 0 10px 30px rgba(59, 130, 246, 0.2);
        transform: translateY(-5px);
    }

    .mode-arrange::before {
        background: var(--mode-arrange);
    }

    .mode-arrange .mode-icon {
        color: var(--mode-arrange);
        background: rgba(16, 185, 129, 0.1);
    }

    .mode-arrange:hover {
        border-color: var(--mode-arrange);
        box-shadow: 0 10px 30px rgba(16, 185, 129, 0.2);
        transform: translateY(-5px);
    }

    .mode-all::before {
        background: var(--mode-all);
    }

    .mode-all .mode-icon {
        color: var(--mode-all);
        background: rgba(139, 92, 246, 0.1);
    }

    .mode-all:hover {
        border-color: var(--mode-all);
        box-shadow: 0 10px 30px rgba(139, 92, 246, 0.2);
        transform: translateY(-5px);
    }

    .mode-icon {
        width: 60px;
        height: 60px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin-bottom: 16px;
    }

    .mode-title {
        color: var(--text-main);
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .mode-desc {
        color: var(--text-muted);
        font-size: 13px;
        line-height: 1.4;
    }

    /* Khay câu hỏi và đáp án */
    .btn-answer-box {
        border: 1.5px solid var(--border-color) !important;
        border-radius: 12px !important;
        padding: 16px 20px;
        background: rgba(30, 41, 59, 0.7) !important;
        color: var(--text-main) !important;
        font-weight: 500;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        text-align: left;
        width: 100%;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .btn-answer-box:hover:not([disabled]) {
            background-color: var(--primary-light) !important;
            border-color: var(--primary-color) !important;
            transform: translateY(-2px);
        }

        .btn-answer-box.correct-answer {
            background-color: var(--success-light) !important;
            border-color: var(--success-color) !important;
            color: #A7F3D0 !important;
        }

        .btn-answer-box.wrong-answer {
            background-color: var(--danger-light) !important;
            border-color: var(--danger-color) !important;
            color: #FCA5A5 !important;
        }

    .badge-word-item {
        background-color: #334155 !important;
        color: #F1F5F9 !important;
        padding: 10px 18px !important;
        border-radius: 10px !important;
        font-size: 14px !important;
        font-weight: 600 !important;
        border: 1px solid #475569 !important;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-block;
        user-select: none;
    }
</style>

<div class="container py-4">
    <div class="mb-4 text-center text-md-left">
        <h3 class="font-weight-bold mb-1" style="color: var(--text-main); letter-spacing: -0.5px;">
            🇯🇵 HỆ THỐNG LUYỆN TẬP NIHONMANABU
        </h3>
        <p class="text-muted mb-0" style="font-size: 13px;">Học và thực hành cấu trúc ngữ pháp Tiếng Nhật</p>
    </div>

    <div class="custom-breadcrumb">
        <a href="?" class="breadcrumb-step @(!Model.LevelId.HasValue ? "active-step" : "")">
            <i class="fas fa-home mr-1"></i> Trang chủ
        </a>
        @if (Model.LevelId.HasValue)
        {
            <span class="breadcrumb-separator"><i class="fas fa-chevron-right"></i></span>
            var currentLvl = Model.Levels.FirstOrDefault(l => l.Id == Model.LevelId);
            <a href="?levelId=@Model.LevelId" class="breadcrumb-step @(!Model.LessonId.HasValue ? "active-step" : "")">
                🎯 @(currentLvl != null ? currentLvl.Name : "Trình độ")
            </a>
        }
        @if (Model.LessonId.HasValue)
        {
            <span class="breadcrumb-separator"><i class="fas fa-chevron-right"></i></span>
            var currentLes = Model.Lessons.FirstOrDefault(l => l.Id == Model.LessonId);
            <a href="?levelId=@Model.LevelId&lessonId=@Model.LessonId" class="breadcrumb-step @(!Model.SelectedGrammarId.HasValue ? "active-step" : "")">
                📖 Bài @(currentLes != null ? currentLes.Order : "")
            </a>
        }
        @if (Model.SelectedGrammarId.HasValue && Model.currentGrammar != null)
        {
            <span class="breadcrumb-separator"><i class="fas fa-chevron-right"></i></span>
            <span class="breadcrumb-step active-step text-truncate" style="max-width: 250px;">
                📢 @Model.currentGrammar.Structure
            </span>
        }
    </div>

    <div class="row">
        <div class="col-12">

            @* TẦNG 1: CHỌN TRÌNH ĐỘ (ĐÃ THAY ĐỔI THÀNH CARD MODERN LẬP THỂ) *@
            @if (!Model.LevelId.HasValue)
            {
                <div class="card custom-card animate__animated animate__fadeIn">
                    <div class="card-header"><i class="fas fa-layer-group text-primary mr-2"></i> Bước 1: Vui lòng chọn Trình độ học tập</div>
                    <div class="card-body p-4">
                        <div class="level-layout-grid">
                            @foreach (var lvl in Model.Levels)
                            {
                                <a href="?levelId=@lvl.Id" class="level-modern-btn">
                                    <div class="lvl-badge">@lvl.Name</div>
                                    <div class="lvl-status">Bấm để mở rộng</div>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }

            @* TẦNG 2 + 3: CHỌN BÀI HỌC (ĐÃ THAY ĐỔI THÀNH Ô VUÔNG DASHBOARD GRID ĐỀU TĂM TẮP) *@
            else if (Model.LevelId.HasValue && !Model.LessonId.HasValue)
            {
                <div class="card custom-card animate__animated animate__fadeIn">
                    <div class="card-header"><i class="fas fa-book-open text-success mr-2"></i> Bước 2: Chọn bài học thực hành</div>
                    <div class="card-body p-4">
                        @if (Model.Lessons != null && Model.Lessons.Any())
                        {
                            <div class="lesson-modern-grid">
                                @foreach (var les in Model.Lessons)
                                {
                                    <a href="?levelId=@Model.LevelId&lessonId=@les.Id" class="lesson-modern-item">
                                        <span class="number">Bài @les.Order</span>
                                        <span class="sub-text">Lesson</span>
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted">Dữ liệu bài học đang được cập nhật...</div>
                        }
                    </div>
                </div>
            }

            @* TẦNG 4: CHỌN CẤU TRÚC NGỮ PHÁP *@
            else if (Model.LessonId.HasValue && !Model.SelectedGrammarId.HasValue)
            {
                <div class="card custom-card animate__animated animate__fadeIn">
                    <div class="card-header"><i class="fas fa-bookmark text-danger mr-2"></i> Bước 3: Chọn cấu trúc Ngữ Pháp cần luyện tập</div>
                    <div class="card-body p-4">
                        @if (Model.Grammars != null && Model.Grammars.Any())
                        {
                            <div class="grammar-modern-list">
                                @foreach (var g in Model.Grammars)
                                {
                                    <a href="?levelId=@Model.LevelId&lessonId=@Model.LessonId&selectedGrammarId=@g.Id" class="grammar-modern-row">
                                        <span>📢 @g.Structure</span>
                                        <i class="fas fa-arrow-right opacity-40"></i>
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted">Bài học này chưa có dữ liệu ngữ pháp.</div>
                        }
                    </div>
                </div>
            }

            @* TẦNG 5: KHỐI NGỮ PHÁP (ĐÃ RE-DESIGN ĐẸP HƠN NHIỀU) & BÀI TẬP *@
            else if (Model.SelectedGrammarId.HasValue && Model.currentGrammar != null)
            {
                @* KHỐI KIẾN THỨC NỀN TẢNG THIẾT KẾ PHÂN TÁCH CAO CẤP *@
                <div class="knowledge-premium-box animate__animated animate__fadeIn">
                    <div class="knowledge-banner">
                        <i class="fas fa-graduation-cap"></i> KIẾN THỨC CỐT LÕI CỦA BÀI HỌC
                    </div>
                    <div class="knowledge-body">
                        <div class="grammar-main-title">@Model.currentGrammar.Structure</div>

                        <div class="explanation-inner-card">
                            <h6 class="font-weight-bold text-primary mb-2" style="font-size: 13px;">
                                <i class="fas fa-info-circle mr-1"></i> Ý nghĩa & Giải thích cấu trúc:
                            </h6>
                            <p class="mb-0" style="white-space: pre-line; font-size: 15px; line-height: 1.6; color: #E2E8F0;">
                                @Model.currentGrammar.Explanation
                            </p>
                        </div>
                    </div>
                </div>

                @* TRẠNG THÁI A: CHƯA CHỌN CHẾ ĐỘ LÀM BÀI *@
                @if (Request.Query["questionType"].Count == 0)
                {
                    <div class="animate__animated animate__fadeInUp animate__fast">
                        <div class="text-center my-3">
                            <h5 class="font-weight-bold" style="color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; font-size: 12px;">Vui lòng lựa chọn chế độ luyện tập phía dưới</h5>
                        </div>

                        <div class="mode-selection-container">
                            <a href="?levelId=@Model.LevelId&lessonId=@Model.LessonId&selectedGrammarId=@Model.SelectedGrammarId&questionType=1" class="mode-card mode-quiz">
                                <div class="mode-icon"><i class="fas fa-list-ul"></i></div>
                                <div class="mode-title">Bài Tập Trắc Nghiệm</div>
                                <div class="mode-desc">Luyện tập chọn đáp án đúng để điền vào chỗ trống trong câu.</div>
                            </a>

                            <a href="?levelId=@Model.LevelId&lessonId=@Model.LessonId&selectedGrammarId=@Model.SelectedGrammarId&questionType=2" class="mode-card mode-arrange">
                                <div class="mode-icon"><i class="fas fa-random"></i></div>
                                <div class="mode-title">Bài Tập Sắp Xếp</div>
                                <div class="mode-desc">Xếp các thẻ từ xáo trộn thành một câu ngữ pháp hoàn chỉnh đúng nghĩa.</div>
                            </a>

                            <a href="?levelId=@Model.LevelId&lessonId=@Model.LessonId&selectedGrammarId=@Model.SelectedGrammarId&questionType=0" class="mode-card mode-all">
                                <div class="mode-icon"><i class="fas fa-layer-group"></i></div>
                                <div class="mode-title">Bài Tập Tổng Hợp</div>
                                <div class="mode-desc">Bao gồm toàn bộ tất cả câu hỏi cả trắc nghiệm và sắp xếp câu.</div>
                            </a>
                        </div>
                    </div>
                }
                @* TRẠNG THÁI B: ĐÃ CHỌN CHẾ ĐỘ - LÀM BÀI TẬP *@
                else
                {
                    <div class="card custom-card animate__animated animate__fadeInUp">
                        <div class="card-header d-flex justify-content-between align-items-center py-3">
                            <h6 class="m-0 font-weight-bold" style="color: var(--text-main);">
                                <i class="fas fa-pencil-alt text-warning mr-2"></i>
                                @(Model.QuestionType == 1 ? "Chế độ: Trắc Nghiệm" : Model.QuestionType == 2 ? "Chế độ: Sắp Xếp Câu" : "Chế độ: Tổng Hợp Tất Cả")
                            </h6>
                            <a href="?levelId=@Model.LevelId&lessonId=@Model.LessonId&selectedGrammarId=@Model.SelectedGrammarId" class="btn btn-xs btn-outline-info px-3" style="border-radius: 8px; font-size: 12px;">
                                <i class="fas fa-exchange-alt mr-1"></i> Đổi chế độ bài tập
                            </a>
                        </div>

                        <div class="card-body p-4" style="background-color: rgba(15, 23, 42, 0.4);">
                            @if (Model.Questions == null || !Model.Questions.Any())
                            {
                                <div class="text-center py-5 text-muted">
                                    <i class="fas fa-exclamation-circle fa-2x mb-2"></i>
                                    <p class="mb-0 small font-weight-bold">Hiện tại chưa có câu hỏi nào trong danh mục này.</p>
                                </div>
                            }
                            else
                            {
                                var index = 1;
                                @foreach (var q in Model.Questions)
                                {
                                    <div class="p-4 mb-4 rounded-lg" style="background: #1E293B; border: 1px solid var(--border-color); border-radius: 12px !important;">
                                        <div class="d-flex align-items-start mb-3">
                                            <span class="badge badge-primary mr-2 px-2 py-1" style="border-radius: 6px; font-size: 11px;">Câu @index</span>
                                            <h6 class="text-white font-weight-bold m-0 pt-1" style="line-height: 1.5; font-size: 16px;">@q.Content</h6>
                                        </div>

                                        @if (q.QuestionType == 1)
                                        {
                                            <div class="row mx-n2 mt-2">
                                                @foreach (var a in q.Answers)
                                                {
                                                    <div class="col-md-6 px-2 mb-2">
                                                        <button class="btn btn-answer-box evaluate-answer" data-correct="@a.IsCorrect.ToString().ToLower()">
                                                            <span class="indicator-dot" style="width: 8px; height: 8px; background-color: var(--primary-color); border-radius: 50%; display: inline-block;"></span>
                                                            <span>@a.Text</span>
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else if (q.QuestionType == 2)
                                        {
                                            <div class="mt-2">
                                                <div class="mb-2 text-muted small"><i class="far fa-lightbulb text-warning mr-1"></i> Nhấp chuột vào các thẻ để sắp xếp:</div>
                                                <div class="d-flex flex-wrap p-3 rounded-lg align-items-center" style="border: 1.5px dashed var(--border-color); gap: 8px; background: rgba(0,0,0,0.15); min-height: 58px;">
                                                    @foreach (var a in q.Answers.OrderBy(x => Guid.NewGuid()))
                                                    {
                                                        <span class="badge-word-item" onclick="toggleWordSelection(this)">@a.Text</span>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    index++;
                                }
                            }
                        </div>
                    </div>
                }
            }

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const answerButtons = document.querySelectorAll('.evaluate-answer');
        answerButtons.forEach(button => {
            button.addEventListener('click', function() {
                const parentRow = this.closest('.row');
                const allButtonsInQuestion = parentRow.querySelectorAll('.evaluate-answer');

                allButtonsInQuestion.forEach(btn => btn.setAttribute('disabled', 'true'));

                const isCorrect = this.getAttribute('data-correct') === 'true';
                if (isCorrect) {
                    this.classList.add('correct-answer');
                    this.querySelector('.indicator-dot').style.backgroundColor = 'var(--success-color)';
                } else {
                    this.classList.add('wrong-answer');
                    this.querySelector('.indicator-dot').style.backgroundColor = 'var(--danger-color)';

                    allButtonsInQuestion.forEach(btn => {
                        if(btn.getAttribute('data-correct') === 'true') {
                            btn.classList.add('correct-answer');
                            btn.querySelector('.indicator-dot').style.backgroundColor = 'var(--success-color)';
                        }
                    });
                }
            });
        });
    });

    function toggleWordSelection(element) {
        element.classList.toggle('selected-word');
    }
</script>