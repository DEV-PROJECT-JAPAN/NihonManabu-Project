@page
@model FrontendRazorPage.Pages.Features.Grammar.IndexModel
@{
    ViewData["Title"] = "Luyện Tập Ngữ Pháp Tiếng Nhật";
}

<style>
    :root {
        --primary-color: #3B82F6;
        --primary-light: rgba(59, 130, 246, 0.12);
        --primary-glow: rgba(59, 130, 246, 0.3);
        --card-bg: #1E293B;
        --text-main: #F1F5F9;
        --text-muted: #94A3B8;
        --border-color: #334155;
        --bg-inner: #0F172A;
        --success-color: #10B981;
        --success-light: rgba(16, 185, 129, 0.15);
        --danger-color: #EF4444;
        --danger-light: rgba(239, 68, 68, 0.15);
        
        --mode-quiz: #3B82F6;
        --mode-arrange: #10B981;
        --mode-all: #8B5CF6;
    }

    body {
        background-color: #0F172A;
        color: var(--text-main);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    /* Thẻ Card Tổng Thể Cao Cấp */
    .custom-card {
        border: 1px solid var(--border-color) !important;
        border-radius: 20px !important;
        background: linear-gradient(145deg, #1E293B, #131C2E) !important;
        overflow: hidden;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
    }

    .custom-card .card-header {
        background: rgba(255, 255, 255, 0.03) !important;
        border-bottom: 1px solid var(--border-color) !important;
        padding: 20px 26px;
        font-weight: 700;
        font-size: 16px;
        letter-spacing: 0.5px;
        color: var(--text-main) !important;
    }

    /* THANH BREADCRUMB GỐC */
    .custom-breadcrumb {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
        background: #172033;
        border: 1px solid var(--border-color);
        padding: 14px 24px;
        border-radius: 14px;
        margin-bottom: 28px;
    }

    .breadcrumb-step {
        display: flex;
        align-items: center;
        font-size: 14px;
        font-weight: 600;
        color: var(--text-muted);
        text-decoration: none !important;
        transition: all 0.2s ease;
    }

    .breadcrumb-step:hover:not(.active-step) { color: var(--primary-color); }
    .breadcrumb-step.active-step {
        color: #FFFFFF;
        background: var(--primary-light);
        padding: 6px 14px;
        border-radius: 8px;
        border: 1px solid rgba(59, 130, 246, 0.25);
    }
    .breadcrumb-separator { color: var(--border-color); font-size: 12px; }

    /* TẦNG 1: THIẾT KẾ CARD LEVEL GỐC */
    .level-layout-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 20px;
        padding: 10px 0;
    }

    .level-modern-btn {
        background: linear-gradient(135deg, #243149, #1A2436);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 26px 20px;
        text-align: center;
        color: var(--text-main);
        text-decoration: none !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }

    .level-modern-btn .lvl-badge {
        font-size: 24px;
        font-weight: 800;
        background: linear-gradient(135deg, #60A5FA, #3B82F6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .level-modern-btn .lvl-status { font-size: 13px; font-weight: 500; color: var(--text-muted); }
    .level-modern-btn:hover {
        border-color: var(--primary-color);
        box-shadow: 0 8px 24px rgba(59, 130, 246, 0.25);
        transform: translateY(-4px);
        background: linear-gradient(135deg, #2B3B59, #1E293F);
    }

    /* Đúp dấu @@ cho media query trong Razor View */
    @@media (max-width: 992px) {
        .welcome-dashboard-grid { grid-template-columns: 1fr !important; }
    }

    .welcome-dashboard-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 28px;
    }

    .stat-mini-card {
        background: rgba(30, 41, 59, 0.6);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        gap: 18px;
    }

    .stat-icon-wrapper {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }
    .stat-info .num { font-size: 22px; font-weight: 800; color: #FFFFFF; line-height: 1.2; }
    .stat-info .lbl { font-size: 13px; color: var(--text-muted); margin-top: 2px; }

    .tip-premium-box {
        background: linear-gradient(145deg, #1E293B, #0F172A);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 24px;
        margin-top: 24px;
        display: flex;
        gap: 16px;
        align-items: flex-start;
    }

    /* TẦNG 2 + 3: BÀI HỌC DẠNG GRID GỐC */
    .lesson-modern-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(95px, 1fr));
        gap: 14px;
        padding: 10px 0;
    }

    .lesson-modern-item {
        background: #1E293B;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 18px 10px;
        text-align: center;
        text-decoration: none !important;
        transition: all 0.25s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
    .lesson-modern-item .number { font-size: 16px; font-weight: 700; color: var(--text-main); }
    .lesson-modern-item .sub-text { font-size: 11px; color: var(--text-muted); margin-top: 2px; text-transform: uppercase; }
    .lesson-modern-item:hover { border-color: var(--success-color); background: var(--success-light); transform: scale(1.03); }
    .lesson-modern-item:hover .number { color: var(--success-color); }

    /* TẦNG 4: DANH SÁCH NGỮ PHÁP TINH TẾ GỐC */
    .grammar-modern-list { display: flex; flex-direction: column; gap: 12px; }
    .grammar-modern-row { background: rgba(255, 255, 255, 0.01); border: 1px solid var(--border-color); border-radius: 14px; padding: 18px 24px; color: var(--text-main); font-weight: 600; font-size: 15px; text-decoration: none !important; display: flex; justify-content: space-between; align-items: center; transition: all 0.25s ease; }
    .grammar-modern-row:hover { border-color: var(--danger-color); background: var(--danger-light); transform: translateX(6px); }

    /* TẦNG 5: KHỐI KIẾN THỨC NỀN TẢNG */
    .knowledge-premium-box { background: #1E293B; border: 1px solid var(--border-color); border-radius: 20px; overflow: hidden; margin-bottom: 28px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2); }
    .knowledge-banner { background: linear-gradient(90deg, #1E40AF, #3B82F6); padding: 14px 24px; font-size: 11px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; color: #FFFFFF; display: flex; align-items: center; gap: 8px; }
    .knowledge-body { padding: 28px; }
    .grammar-main-title { font-size: 26px; font-weight: 800; color: #FFFFFF; letter-spacing: -0.5px; margin-bottom: 20px; display: inline-block; padding-bottom: 6px; border-bottom: 3px solid var(--primary-color); }
    .explanation-inner-card { background-color: var(--bg-inner); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 12px; padding: 20px; }

    /* 3 Card Mode Lựa chọn bài tập phẳng */
    .mode-selection-container { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 24px; }
    @@media (max-width: 768px) { .mode-selection-container { grid-template-columns: 1fr; } }
    .mode-card { background: linear-gradient(145deg, #1E293B, #151F32); border: 2px solid var(--border-color); border-radius: 20px; padding: 35px 20px; text-align: center; text-decoration: none !important; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; position: relative; overflow: hidden; }
    .mode-card::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 4px; }
    .mode-quiz::before { background: var(--mode-quiz); }
    .mode-quiz .mode-icon { color: var(--mode-quiz); background: rgba(59, 130, 246, 0.1); }
    .mode-quiz:hover { border-color: var(--mode-quiz); box-shadow: 0 10px 30px rgba(59, 130, 246, 0.2); transform: translateY(-5px); }
    .mode-arrange::before { background: var(--mode-arrange); }
    .mode-arrange .mode-icon { color: var(--mode-arrange); background: rgba(16, 185, 129, 0.1); }
    .mode-arrange:hover { border-color: var(--mode-arrange); box-shadow: 0 10px 30px rgba(16, 185, 129, 0.2); transform: translateY(-5px); }
    .mode-all::before { background: var(--mode-all); }
    .mode-all .mode-icon { color: var(--mode-all); background: rgba(139, 92, 246, 0.1); }
    .mode-all:hover { border-color: var(--mode-all); box-shadow: 0 10px 30px rgba(139, 92, 246, 0.2); transform: translateY(-5px); }
    .mode-icon { width: 60px; height: 60px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 16px; }
    .mode-title { color: var(--text-main); font-size: 18px; font-weight: 700; margin-bottom: 6px; }
    .mode-desc { color: var(--text-muted); font-size: 13px; line-height: 1.4; }

    /* NÚT ĐỔI CHẾ ĐỘ BÀI TẬP GLASSMORPHISM */
    .btn-change-mode {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #60A5FA !important;
        font-weight: 600;
        font-size: 13px;
        padding: 8px 18px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none !important;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .btn-change-mode:hover { background: var(--primary-light); border-color: rgba(59, 130, 246, 0.4); color: #FFFFFF !important; }

    /* TÁI CẤU TRÚC GIAO DIỆN LÀM BÀI TẬP PHẲNG TOÁN ĐÃNG */
    .exercise-clean-row {
        padding: 28px 12px;
        border-bottom: 1px solid var(--border-color);
    }
    .exercise-clean-row:last-child { border-bottom: none; }

    /* Ô đáp án trắc nghiệm phẳng tối giản */
    .btn-answer-box {
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        border-radius: 10px !important;
        padding: 14px 18px;
        background: rgba(15, 23, 42, 0.3) !important;
        color: #CBD5E1 !important;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.15s ease;
        text-align: left;
        width: 100%;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .btn-answer-box:hover:not([disabled]) { border-color: var(--primary-color) !important; background: rgba(255, 255, 255, 0.02) !important; color: #FFFFFF !important; }
    .btn-answer-box.correct-answer { background-color: var(--success-light) !important; border-color: var(--success-color) !important; color: #A7F3D0 !important; }
    .btn-answer-box.wrong-answer { background-color: var(--danger-light) !important; border-color: var(--danger-color) !important; color: #FCA5A5 !important; }

    /* VÙNG LẮP GHÉP CÂU SẮP XẾP SẪM NHẸ */
    .sentence-assembly-zone {
        border: 1px dashed #475569;
        background: rgba(15, 23, 42, 0.4);
        min-height: 54px;
        border-radius: 10px;
        padding: 10px 14px;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        align-items: center;
    }
    .sentence-assembly-zone.correct-zone { border-color: var(--success-color); background: rgba(16, 185, 129, 0.02); }
    .sentence-assembly-zone.wrong-zone { border-color: var(--danger-color); background: rgba(239, 68, 68, 0.02); }

    .badge-word-item {
        background-color: #1E293B !important;
        color: #E2E8F0 !important;
        padding: 8px 14px !important;
        border-radius: 8px !important;
        font-size: 14px !important;
        font-weight: 600 !important;
        border: 1px solid var(--border-color) !important;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-block;
        user-select: none;
    }
    .badge-word-item.disabled-pool-word { opacity: 0.15; cursor: not-allowed; border-style: dashed !important; background-color: transparent !important; }

    /* NÚT LOA MINI TINH TẾ - TUYỆT ĐỐI CHỈ HIỆN KHI CÓ KẾT QUẢ ĐÁP ÁN */
    .btn-audio-speaker {
        background: rgba(59, 130, 246, 0.15);
        border: 1px solid rgba(59, 130, 246, 0.3);
        color: #60A5FA;
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .btn-audio-speaker:hover { background: var(--primary-color); color: #FFFFFF; }
</style>

<div class="container py-4">
    <div class="mb-4 text-center text-md-left">
        <h3 class="font-weight-bold mb-1" style="color: var(--text-main); letter-spacing: -0.5px;">
            🇯🇵 HỆ THỐNG LUYỆN TẬP NIHONMANABU
        </h3>
        <p class="text-muted mb-0" style="font-size: 13px;">Học và thực hành cấu trúc ngữ pháp Tiếng Nhật</p>
    </div>

    <div class="custom-breadcrumb">
        <a href="?" class="breadcrumb-step @(!Model.LevelId.HasValue ? "active-step" : "")"><i class="fas fa-home mr-1"></i> Trang chủ</a>
        @if (Model.LevelId.HasValue)
        {
            <span class="breadcrumb-separator"><i class="fas fa-chevron-right"></i></span>
            var currentLvl = Model.Levels.FirstOrDefault(l => l.Id == Model.LevelId);
            <a href="?levelId=@Model.LevelId" class="breadcrumb-step @(!Model.LessonId.HasValue ? "active-step" : "")">🎯 @(currentLvl != null ? currentLvl.Name : "Trình độ")</a>
        }
        @if (Model.LessonId.HasValue)
        {
            <span class="breadcrumb-separator"><i class="fas fa-chevron-right"></i></span>
            var currentLes = Model.Lessons.FirstOrDefault(l => l.Id == Model.LessonId);
            <a href="?levelId=@Model.LevelId&lessonId=@Model.LessonId" class="breadcrumb-step @(!Model.SelectedGrammarId.HasValue ? "active-step" : "")">📖 Bài @(currentLes != null ? currentLes.Order : "")</a>
        }
        @if (Model.SelectedGrammarId.HasValue && Model.currentGrammar != null)
        {
            <span class="breadcrumb-separator"><i class="fas fa-chevron-right"></i></span>
            <span class="breadcrumb-step active-step text-truncate" style="max-width: 250px;">📢 @Model.currentGrammar.Structure</span>
        }
    </div>

    <div class="row">
        <div class="col-12">

            @* TẦNG 1: CHỌN TRÌNH ĐỘ *@
            @if (!Model.LevelId.HasValue)
            {
                <div class="card custom-card animate__animated animate__fadeIn">
                    <div class="card-header"><i class="fas fa-layer-group text-primary mr-2"></i> Bước 1: Vui lòng chọn Trình độ học tập</div>
                    <div class="card-body p-4">
                        <div class="level-layout-grid">
                            @foreach (var lvl in Model.Levels)
                            {
                                <a href="?levelId=@lvl.Id" class="level-modern-btn">
                                    <div class="lvl-badge">@lvl.Name</div>
                                    <div class="lvl-status">Bấm để mở rộng</div>
                                </a>
                            }
                        </div>
                    </div>
                </div>

                @* KHỐI FIX TRỐNG GIAO DIỆN Ở TRANG CHỦ THEO MẪU GỐC *@
                <div class="welcome-dashboard-grid animate__animated animate__fadeInUp animate__delay-1s">
                    <div class="stat-mini-card">
                        <div class="stat-icon-wrapper" style="background: rgba(59, 130, 246, 0.15); color: #3B82F6;"><i class="fas fa-graduation-cap"></i></div>
                        <div class="stat-info"><div class="num">150+</div><div class="lbl">Mẫu cấu trúc ngữ pháp</div></div>
                    </div>
                    <div class="stat-mini-card">
                        <div class="stat-icon-wrapper" style="background: rgba(16, 185, 129, 0.15); color: #10B981;"><i class="fas fa-check-double"></i></div>
                        <div class="stat-info"><div class="num">2,400+</div><div class="lbl">Câu hỏi thực hành live</div></div>
                    </div>
                    <div class="stat-mini-card">
                        <div class="stat-icon-wrapper" style="background: rgba(245, 158, 11, 0.15); color: #F59E0B;"><i class="fas fa-fire"></i></div>
                        <div class="stat-info"><div class="num">Hàng ngày</div><div class="lbl">Cập nhật kho đề mới</div></div>
                    </div>
                </div>

                <div class="tip-premium-box animate__animated animate__fadeInUp animate__delay-1s">
                    <div class="stat-icon-wrapper" style="background: rgba(139, 92, 246, 0.15); color: #8B5CF6; font-size: 18px; padding: 16px; width: 44px; height: 44px;"><i class="fas fa-lightbulb"></i></div>
                    <div>
                        <h6 class="font-weight-bold mb-1" style="color: #FFFFFF; font-size: 14px;">Gợi ý lộ trình học hiệu quả:</h6>
                        <p class="text-muted mb-0 small" style="line-height: 1.5;">
                            Hệ thống khuyến nghị bạn nên bắt đầu luyện tập theo thứ tự từ các trình độ cơ bản <strong>N5 -> N4</strong> trước khi thử sức với các bài tập sắp xếp chuỗi từ phức tạp ở trình độ cao cấp. Việc làm đi làm lại một cấu trúc ngữ pháp sẽ tạo phản xạ giao tiếp tự nhiên cực tốt. Chúc bạn có một buổi học đầy năng suất.
                        </p>
                        <p class="text-muted mb-0 small" style="line-height: 1.5;">
                            Chúc bạn có một buổi học vui vẻ và hiệu quả với hệ thống luyện tập ngữ pháp của Nihonmanabu! Hãy tận dụng tối đa các bài tập thực hành để củng cố kiến thức và nâng cao kỹ năng tiếng Nhật của mình nhé.
                        </p>
                    </div>
                </div>
            }

            @* TẦNG 2 + 3: CHỌN BÀI HỌC *@
            else if (Model.LevelId.HasValue && !Model.LessonId.HasValue)
            {
                <div class="card custom-card animate__animated animate__fadeIn">
                    <div class="card-header"><i class="fas fa-book-open text-success mr-2"></i> Bước 2: Chọn bài học thực hành</div>
                    <div class="card-body p-4">
                        @if (Model.Lessons != null && Model.Lessons.Any())
                        {
                            <div class="lesson-modern-grid">
                                @foreach (var les in Model.Lessons)
                                {
                                    <a href="?levelId=@Model.LevelId&lessonId=@les.Id" class="lesson-modern-item">
                                        <span class="number">Bài @les.Order</span>
                                        <span class="sub-text">Lesson</span>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            @* TẦNG 4: CHỌN CẤU TRÚC NGỮ PHÁP *@
            else if (Model.LessonId.HasValue && !Model.SelectedGrammarId.HasValue)
            {
                <div class="card custom-card animate__animated animate__fadeIn">
                    <div class="card-header"><i class="fas fa-bookmark text-danger mr-2"></i> Bước 3: Chọn cấu trúc Ngữ Pháp cần luyện tập</div>
                    <div class="card-body p-4">
                        @if (Model.Grammars != null && Model.Grammars.Any())
                        {
                            <div class="grammar-modern-list">
                                @foreach (var g in Model.Grammars)
                                {
                                    <a href="?levelId=@Model.LevelId&lessonId=@Model.LessonId&selectedGrammarId=@g.Id" class="grammar-modern-row">
                                        <span>📢 @g.Structure</span>
                                        <i class="fas fa-arrow-right opacity-40"></i>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            @* TẦNG 5: KHỐI NGỮ PHÁP VÀ KHAY BÀI TẬP *@
            else if (Model.SelectedGrammarId.HasValue && Model.currentGrammar != null)
            {
                <div class="knowledge-premium-box animate__animated animate__fadeIn">
                    <div class="knowledge-banner"><i class="fas fa-graduation-cap"></i> KIẾN THỨC CỐT LÕI CỦA BÀI HỌC</div>
                    <div class="knowledge-body">
                        <div class="grammar-main-title">@Model.currentGrammar.Structure</div>
                        <div class="explanation-inner-card">
                            <h6 class="font-weight-bold text-primary mb-2" style="font-size: 13px;"><i class="fas fa-info-circle mr-1"></i> Ý nghĩa & Giải thích cấu trúc:</h6>
                            <p class="mb-0" style="white-space: pre-line; font-size: 15px; line-height: 1.6; color: #E2E8F0;">@Model.currentGrammar.Explanation</p>
                        </div>
                    </div>
                </div>

                @if (Request.Query["questionType"].Count == 0)
                {
                    <div class="animate__animated animate__fadeInUp animate__fast">
                        <div class="text-center my-3"><h5 class="font-weight-bold" style="color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; font-size: 12px;">Vui lòng lựa chọn chế độ luyện tập phía dưới</h5></div>
                        <div class="mode-selection-container">
                            <a href="?levelId=@Model.LevelId&lessonId=@Model.LessonId&selectedGrammarId=@Model.SelectedGrammarId&questionType=1" class="mode-card mode-quiz">
                                <div class="mode-icon"><i class="fas fa-list-ul"></i></div>
                                <div class="mode-title">Bài Tập Trắc Nghiệm</div>
                                <div class="mode-desc">Luyện tập chọn đáp án đúng để điền vào chỗ trống trong câu.</div>
                            </a>
                            <a href="?levelId=@Model.LevelId&lessonId=@Model.LessonId&selectedGrammarId=@Model.SelectedGrammarId&questionType=2" class="mode-card mode-arrange">
                                <div class="mode-icon"><i class="fas fa-random"></i></div>
                                <div class="mode-title">Bài Tập Sắp Xếp</div>
                                <div class="mode-desc">Xếp các thẻ từ xáo trộn thành một câu ngữ pháp hoàn chỉnh đúng nghĩa.</div>
                            </a>
                            <a href="?levelId=@Model.LevelId&lessonId=@Model.LessonId&selectedGrammarId=@Model.SelectedGrammarId&questionType=0" class="mode-card mode-all">
                                <div class="mode-icon"><i class="fas fa-layer-group"></i></div>
                                <div class="mode-title">Bài Tập Tổng Hợp</div>
                                <div class="mode-desc">Bao gồm toàn bộ tất cả câu hỏi cả trắc nghiệm và sắp xếp câu.</div>
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card custom-card animate__animated animate__fadeInUp">
                        <div class="card-header d-flex justify-content-between align-items-center py-3">
                            <h6 class="m-0 font-weight-bold" style="color: var(--text-muted); font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px;">
                                <i class="fas fa-pencil-alt text-warning mr-2"></i> Khay bài tập thực hành
                            </h6>
                            <a href="?levelId=@Model.LevelId&lessonId=@Model.LessonId&selectedGrammarId=@Model.SelectedGrammarId" class="btn-change-mode">
                                <i class="fas fa-exchange-alt"></i> Đổi chế độ
                            </a>
                        </div>
                        <div class="card-body p-0" style="background-color: rgba(15, 23, 42, 0.2);">
                            @if (Model.Questions != null && Model.Questions.Any())
                            {
                                var index = 1;
                                @foreach (var q in Model.Questions)
                                {
                                    <div class="exercise-clean-row quiz-question-wrapper mx-4" data-question-content="@q.Content">
                                        <div class="d-flex align-items-center mb-3">
                                            <span class="text-primary font-weight-bold mr-2" style="font-size: 15px;">Câu @index.</span>
                                            <h6 class="text-white font-weight-bold m-0" style="line-height: 1.5; font-size: 16px; letter-spacing: 0.1px;">@q.Content</h6>
                                        </div>

                                        @if (q.QuestionType == 1)
                                        {
                                            @* UI TRẮC NGHIỆM TIÊU CHUẨN *@
                                            <div class="row mx-n2 mt-2">
                                                @foreach (var a in q.Answers)
                                                {
                                                    <div class="col-md-6 px-2 mb-2">
                                                        <button class="btn btn-answer-box evaluate-answer" data-correct="@a.IsCorrect.ToString().ToLower()" data-answer-text="@a.Text">
                                                            <span class="indicator-dot" style="width: 6px; height: 8px; background-color: rgba(255,255,255,0.25); border-radius: 50%; display: inline-block;"></span>
                                                            <span>@a.Text</span>
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                            
                                            <div class="quiz-feedback-audio-zone mt-2"></div>
                                        }
                                        else if (q.QuestionType == 2)
                                        {
                                            @* UI SẮP XẾP CÂU PHẲNG - KHÔNG HIỆN LOA KHI CHƯA CHECK *@
                                            <div class="arrange-question-block mt-2" data-correct-sentence="@string.Join(" ", q.Answers.OrderBy(x => x.DisplayOrder).Select(x => x.Text))">
                                                
                                                <div class="sentence-assembly-zone mb-2"></div>
                                                
                                             
                                                <div class="mb-2 text-muted small" style="font-size: 12px;"><i class="far fa-lightbulb text-warning mr-1"></i> Bấm để xếp câu theo thứ tự:</div>
                                                
                                                <div class="d-flex flex-wrap p-2 rounded align-items-center word-pool-container" style="border: 1px solid var(--border-color); gap: 6px; background: rgba(0,0,0,0.15); min-height: 46px;">
                                                    @foreach (var a in q.Answers.OrderBy(x => Guid.NewGuid()))
                                                    {
                                                        <span class="badge-word-item source-word" data-word-text="@a.Text" onclick="handleWordClick(this)">@a.Text</span>
                                                    }
                                                </div>

                                                <div class="feedback-zone-wrapper mt-2"></div>

                                                <div class="d-flex justify-content-end gap-2 mt-2">
                                                    <button class="btn btn-link btn-sm text-muted mr-2" onclick="resetArrangeQuestion(this)" style="font-size: 12px; text-decoration: none;"><i class="fas fa-redo"></i> Xếp lại</button>
                                                    <button class="btn btn-sm btn-primary btn-check-arrange px-4" onclick="checkArrangeAnswer(this)">Kiểm tra</button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    index++;
                                }
                            }
                        </div>
                    </div>
                }
            }

        </div>
    </div>
</div>

<script>
    /**
     * [LIVE-AUDIO] Gọi Web Speech API để phát thanh âm tiếng Nhật
     * @@param {string} text - Câu thoại cần đọc phát thanh
     */
    var speakJapanese = function(text) {
        if ('speechSynthesis' in window) {
            const cleanText = text.replace(/\[\s*\]/g, '').replace(/_+/g, '');
            const utterance = new SpeechSynthesisUtterance(cleanText);
            utterance.lang = 'ja-JP';
            utterance.rate = 0.85; 
            window.speechSynthesis.speak(utterance);
        }
    };

    document.addEventListener("DOMContentLoaded", function() {
        // [XỬ LÝ TRẮC NGHIỆM: CHỈ SINH LOA KHI ĐÃ CHỌN ĐÁP ÁN]
        const answerButtons = document.querySelectorAll('.evaluate-answer');
        answerButtons.forEach(button => {
            button.addEventListener('click', function() {
                const parentRow = this.closest('.row');
                const questionWrapper = this.closest('.quiz-question-wrapper');
                const audioFeedbackZone = questionWrapper.querySelector('.quiz-feedback-audio-zone');
                const allButtonsInQuestion = parentRow.querySelectorAll('.evaluate-answer');
                
                allButtonsInQuestion.forEach(btn => btn.setAttribute('disabled', 'true'));
                
                const isCorrect = this.getAttribute('data-correct') === 'true';
                const originalQuestion = questionWrapper.getAttribute('data-question-content');
                const currentAnswerText = this.getAttribute('data-answer-text');

                let correctBtnText = "";
                allButtonsInQuestion.forEach(btn => {
                    if (btn.getAttribute('data-correct') === 'true') {
                        correctBtnText = btn.getAttribute('data-answer-text');
                    }
                });

                const filledUserSentence = originalQuestion.replace(/\[\s*\]/g, currentAnswerText).replace(/_+/g, currentAnswerText);
                const filledCorrectSentence = originalQuestion.replace(/\[\s*\]/g, correctBtnText).replace(/_+/g, correctBtnText);

                if (isCorrect) {
                    this.classList.add('correct-answer');
                    this.querySelector('.indicator-dot').style.backgroundColor = 'var(--success-color)';
                    
                    audioFeedbackZone.innerHTML = `
                        <div class="animate__animated animate__fadeIn mt-1">
                            <button class="btn-audio-speaker" onclick="speakJapanese('${filledUserSentence}')">
                                <i class="fas fa-volume-up mr-1"></i> Kết quả đúng! Nghe toàn bộ câu 🔊
                            </button>
                        </div>
                    `;
                } else {
                    this.classList.add('wrong-answer');
                    this.querySelector('.indicator-dot').style.backgroundColor = 'var(--danger-color)';
                    
                    allButtonsInQuestion.forEach(btn => {
                        if(btn.getAttribute('data-correct') === 'true') {
                            btn.classList.add('correct-answer');
                            btn.querySelector('.indicator-dot').style.backgroundColor = 'var(--success-color)';
                        }
                    });

                    audioFeedbackZone.innerHTML = `
                        <div class="p-2 rounded d-flex justify-content-between align-items-center mt-2 animate__animated animate__fadeIn" style="background: rgba(16, 185, 129, 0.04); border: 1px solid rgba(16, 185, 129, 0.2);">
                            <div>
                                <span class="text-success font-weight-bold" style="font-size:14px;">${filledCorrectSentence}</span>
                            </div>
                            <button class="btn-audio-speaker" onclick="speakJapanese('${filledCorrectSentence}')">
                                <i class="fas fa-volume-up"></i> Nghe đáp án chuẩn
                            </button>
                        </div>
                    `;
                }
            });
        });
    });

    // [XỬ LÝ SẮP XẾP CÂU: CLICK CHỌN TỪ LÊN KHAY]
    var handleWordClick = function(element) {
        const questionBlock = element.closest('.arrange-question-block');
        const assemblyZone = questionBlock.querySelector('.sentence-assembly-zone');
        if (questionBlock.querySelector('.btn-check-arrange').hasAttribute('disabled')) return;

        if (element.classList.contains('source-word')) {
            if (element.classList.contains('disabled-pool-word')) return;
            element.classList.add('disabled-pool-word');

            const newWord = document.createElement('span');
            newWord.className = 'badge-word-item assembled-word';
            newWord.innerText = element.getAttribute('data-word-text');
            newWord.sourceElement = element;

            newWord.onclick = function() {
                this.sourceElement.classList.remove('disabled-pool-word');
                this.remove();
            };
            assemblyZone.appendChild(newWord);
        }
    };

    // [XỬ LÝ KIỂM TRA ĐÁP ÁN SẮP XẾP: CHỈ KÍCH HOẠT LOA KHI CÓ KẾT QUẢ CHẤM ĐIỂM]
    var checkArrangeAnswer = function(button) {
        const questionBlock = button.closest('.arrange-question-block');
        const assemblyZone = questionBlock.querySelector('.sentence-assembly-zone');
        const audioTrigger = questionBlock.querySelector('.correct-audio-trigger-wrapper');
        const feedbackZone = questionBlock.querySelector('.feedback-zone-wrapper');
        const correctSentence = questionBlock.getAttribute('data-correct-sentence').trim();

        const assembledWords = questionBlock.querySelectorAll('.assembled-word');
        let userSentence = Array.from(assembledWords).map(w => w.innerText).join(" ").trim();

        button.setAttribute('disabled', 'true');

        if (userSentence === correctSentence) {
            // Trường hợp 1: Ghép đúng -> Đổi màu zone và gỡ d-none để HIỂN THỊ nút loa phần thưởng đúng ý bạn
            assemblyZone.classList.add('correct-zone');
            audioTrigger.classList.remove('d-none');
        } else {
            // Trường hợp 2: Ghép sai -> Đổi màu zone và sinh hộp card đáp án kèm nút loa sửa sai
            assemblyZone.classList.add('wrong-zone');
            feedbackZone.innerHTML = `
                <div class="p-2 rounded d-flex justify-content-between align-items-center mt-2 animate__animated animate__fadeIn" style="background: rgba(16, 185, 129, 0.04); border: 1px solid rgba(16, 185, 129, 0.2);">
                    <div>
                        <span class="text-success font-weight-bold" style="font-size:14px;">${correctSentence}</span>
                    </div>
                    <button class="btn-audio-speaker" onclick="speakJapanese('${correctSentence}')">
                        <i class="fas fa-volume-up"></i> Nghe đáp án chuẩn
                    </button>
                </div>
            `;
        }
    };

    var resetArrangeQuestion = function(button) {
        const questionBlock = button.closest('.arrange-question-block');
        const assemblyZone = questionBlock.querySelector('.sentence-assembly-zone');
        const audioTrigger = questionBlock.querySelector('.correct-audio-trigger-wrapper');
        const feedbackZone = questionBlock.querySelector('.feedback-zone-wrapper');

        assemblyZone.innerHTML = '';
        assemblyZone.className = 'sentence-assembly-zone mb-2';
        audioTrigger.classList.add('d-none'); // Ẩn lại nút loa khi làm lại câu hỏi
        feedbackZone.innerHTML = '';

        const poolWords = questionBlock.querySelectorAll('.source-word');
        poolWords.forEach(w => w.classList.remove('disabled-pool-word'));

        const checkBtn = questionBlock.querySelector('.btn-check-arrange');
        checkBtn.removeAttribute('disabled');
    };
</script>